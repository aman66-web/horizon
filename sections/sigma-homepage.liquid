<div class="sigma-home">
<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600&display=swap');
:root{
    --bone:#EDE7DA; --bone-light:#F5F1E8; --bone-card:#F7F4EC;
    --ink:#17302D; --ink-soft:rgba(23,48,45,0.66); --ink-faint:rgba(23,48,45,0.42);
    --teal-deep:#0D3D3E; --teal:#14514F; --teal-mid:#3B7C77; --teal-frost:#D9E5E1;
    --bronze:#A6844E; --bronze-light:#C4A472;
    --line:rgba(23,48,45,0.14); --line-light:rgba(245,241,232,0.16);
  }
.sigma-home *{box-sizing:border-box; margin:0; padding:0;}
.sigma-home{scroll-behavior:smooth;}
.sigma-home{background:var(--bone); color:var(--ink); font-family:'Inter',sans-serif; -webkit-font-smoothing:antialiased; overflow-x:hidden; line-height:1.5;}
.sigma-home h1, .sigma-home h2, .sigma-home h3, .sigma-home h4{font-family:'Fraunces',serif; font-weight:400; letter-spacing:-0.015em; color:var(--ink);}
.sigma-home a{color:inherit; text-decoration:none;}
.sigma-home .wrap{max-width:1200px; margin:0 auto; padding:0 62px 0 40px;}
@media(max-width:560px){.sigma-home .wrap{padding:0 54px 0 22px;}}
.sigma-home ::selection{background:var(--bronze-light); color:var(--ink);}
.sigma-home sup{font-size:0.55em; vertical-align:super; color:var(--bronze); font-family:'IBM Plex Mono',monospace;}
.sigma-home .eyebrow{font-family:'IBM Plex Mono',monospace; font-size:11.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--bronze); display:inline-flex; align-items:center; gap:11px;}
.sigma-home .eyebrow::before{content:'●'; font-size:7px; color:var(--bronze); transform:translateY(-1px);}
.sigma-home .reveal{opacity:1; transform:none;}
.sigma-home.js-anim .reveal{opacity:0; transform:translateY(22px); transition:opacity .8s cubic-bezier(.2,.7,.2,1), transform .8s cubic-bezier(.2,.7,.2,1);}
.sigma-home.js-anim .reveal.in{opacity:1; transform:none;}
@media (prefers-reduced-motion: reduce){.sigma-home .reveal, .sigma-home.js-anim .reveal{opacity:1; transform:none; transition:none;}
.sigma-home{scroll-behavior:auto;}}
.sigma-home nav{position:sticky; top:0; z-index:100; background:rgba(237,231,218,0.82); backdrop-filter:blur(12px); border-bottom:1px solid var(--line);}
.sigma-home .nav-inner{max-width:1200px; margin:0 auto; padding:20px 40px; display:flex; align-items:center; justify-content:space-between;}
.sigma-home .logo{display:flex; align-items:baseline; gap:9px; font-size:17px; letter-spacing:0.02em; font-weight:500;}
.sigma-home .logo .sigma{font-family:'Fraunces',serif; font-size:23px; color:var(--teal-deep); font-weight:500; transform:translateY(2px);}
.sigma-home .nav-links{display:flex; gap:38px; font-size:13.5px; font-weight:500;}
.sigma-home .nav-links a{opacity:0.7; transition:opacity .2s;}
.sigma-home .nav-links a:hover{opacity:1;}
.sigma-home .nav-cta{background:var(--ink); color:var(--bone); padding:11px 24px; border-radius:2px; font-family:'IBM Plex Mono',monospace; font-size:12px; letter-spacing:0.04em; text-transform:uppercase; transition:background .2s;}
.sigma-home .nav-cta:hover{background:var(--teal-deep);}
@media(max-width:880px){.sigma-home .nav-links{display:none;}}
/* ---------- right scroll-progress rail (ported from the product page, brand labels) ---------- */
.sigma-home .home-rail{position:fixed; right:14px; top:50%; transform:translateY(-50%); z-index:90; height:min(470px,72vh); display:flex; flex-direction:column; justify-content:space-between; align-items:center; padding:16px 0;}
.sigma-home .rail-track{position:absolute; left:50%; transform:translateX(-50%); top:28px; bottom:28px; width:2px; border-radius:2px; background:rgba(13,61,62,0.22);}
.sigma-home .rail-fill{position:absolute; left:50%; transform:translateX(-50%); top:28px; width:2px; height:0; border-radius:2px; background:var(--teal-deep); transition:height .5s cubic-bezier(.4,0,.2,1);}
.sigma-home .rail-node{position:relative; z-index:1; display:flex; justify-content:center; align-items:center; background:none; border:none; padding:0; cursor:pointer;}
.sigma-home .rail-node .rn{width:26px; height:26px; border-radius:50%; border:1.5px solid rgba(13,61,62,0.42); background:transparent; color:#0D3D3E; display:flex; align-items:center; justify-content:center; transition:transform .3s, color .4s, border-color .4s, box-shadow .3s;}
.sigma-home .rail-node .rn svg{width:14px; height:14px; stroke:currentColor; fill:none; stroke-width:1.7; stroke-linecap:round; stroke-linejoin:round;}
.sigma-home .rail-node .rl{position:absolute; top:100%; left:50%; transform:translateX(-50%); margin-top:4px; padding:2px 5px; border-radius:3px; font-family:'IBM Plex Mono',monospace; font-size:9px; letter-spacing:0.03em; text-transform:uppercase; color:#0D3D3E; white-space:nowrap; text-align:center; transition:color .4s, background .4s;}
.sigma-home .rail-node.nd .rn{border-color:rgba(237,231,218,0.5); color:#EDE7DA;}
.sigma-home .rail-node.nd .rl{color:#EDE7DA;}
.sigma-home .rail-node.is-active .rn{border-color:#0D3D3E; border-width:2px; transform:scale(1.16); box-shadow:0 0 0 5px rgba(13,61,62,0.10);}
.sigma-home .rail-node.nd.is-active .rn{border-color:#EDE7DA; box-shadow:0 0 0 5px rgba(237,231,218,0.14);}
.sigma-home .rail-node.is-active .rl{font-weight:600;}
.sigma-home .rail-node.is-active .rn{z-index:2;}
@media (max-width:560px){.sigma-home .home-rail{right:12px; height:68vh; padding:12px 0;} .sigma-home .rail-node .rn{width:23px; height:23px;} .sigma-home .rail-node .rn svg{width:12.5px; height:12.5px;} .sigma-home .rail-node .rl{font-size:8px;}}
@media (prefers-reduced-motion:reduce){.sigma-home .rail-fill{transition:height 0s;}}
.sigma-home #home-top,.sigma-home #longevity,.sigma-home #instrument,.sigma-home #formula,.sigma-home #proof,.sigma-home #pricing{scroll-margin-top:86px;}
.sigma-home /* HERO — full-bleed immersive image */
  .hero{position:relative; min-height:92vh; display:flex; align-items:stretch; justify-content:center; text-align:center; background:var(--teal-deep); overflow:hidden;}
.sigma-home .hero-bg{position:absolute; inset:0; z-index:0;}
.sigma-home .hero-bg img{width:100%; height:100%; object-fit:cover; object-position:center; display:block;}
.sigma-home .hero-bg::after{content:''; position:absolute; inset:0; background:linear-gradient(to bottom, rgba(13,61,62,0.96) 0%, rgba(13,61,62,0.8) 24%, rgba(13,61,62,0.16) 42%, rgba(13,61,62,0.16) 60%, rgba(13,61,62,0.74) 80%, rgba(13,61,62,0.95) 100%);}
.sigma-home .hero-content{position:relative; z-index:1; width:100%; max-width:640px; display:flex; flex-direction:column; justify-content:space-between; padding:84px 24px 40px; color:var(--bone);}
.sigma-home .hero-trust-v{position:absolute; left:14px; top:50%; transform:translateY(-50%) rotate(180deg); writing-mode:vertical-rl; z-index:2; font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:var(--bronze-light); opacity:0.9; white-space:nowrap; pointer-events:none;}
.sigma-home .hero-trust{display:inline-flex; align-items:center; gap:10px; font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:0.09em; text-transform:uppercase; color:var(--bronze-light); margin-bottom:22px; flex-wrap:wrap; justify-content:center;}
.sigma-home .hero-trust .dot{opacity:0.5;}
.sigma-home .hero .eyebrow{color:var(--bronze-light); justify-content:center;}
.sigma-home .hero .eyebrow::before{color:var(--bronze-light);}
.sigma-home .hero h1{font-size:clamp(42px,7vw,74px); line-height:1.02; font-weight:300; margin:14px 0 14px; letter-spacing:-0.028em; color:var(--bone);}
.sigma-home .hero .hero-punch{font-family:'Fraunces',serif; font-style:italic; font-weight:400; font-size:clamp(19px,2.7vw,27px); color:var(--bronze-light); margin-bottom:20px;}
.sigma-home .hero .lede{font-size:16.5px; line-height:1.6; color:var(--dark-soft); max-width:480px; margin:0 auto 32px;}
.sigma-home .btn-row{display:flex; gap:14px; align-items:center; flex-wrap:wrap; justify-content:center;}
.sigma-home .btn-primary{background:var(--bone); color:var(--teal-deep); padding:16px 32px; font-size:14px; font-weight:600; border-radius:100px; transition:background .2s, transform .2s;}
.sigma-home .btn-primary:hover{background:#fff; transform:translateY(-1px);}
.sigma-home .btn-ghost{border:1px solid rgba(237,231,218,0.4); color:var(--bone); padding:15px 26px; font-size:14px; font-weight:500; border-radius:100px; transition:border-color .2s, background .2s;}
.sigma-home .btn-ghost:hover{border-color:var(--bone); background:rgba(237,231,218,0.08);}
@media(max-width:880px){
  .sigma-home .hero{min-height:94vh;}
  .sigma-home .hero-content{padding:66px 20px 44px;}
}
.sigma-home /* THESIS */
  .thesis{border-top:1px solid var(--line); border-bottom:1px solid var(--line); background:var(--bone-light);}
.sigma-home .thesis-inner{max-width:1200px; margin:0 auto; padding:34px 62px 34px 40px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:20px;}
.sigma-home .thesis h2{font-size:clamp(22px,2.4vw,30px); font-weight:400; letter-spacing:-0.01em;}
.sigma-home .thesis .meta{font-family:'IBM Plex Mono',monospace; font-size:11.5px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-faint); display:flex; gap:26px; flex-wrap:wrap;}
.sigma-home /* SIGNATURE — INTERACTIVE INSTRUMENT */
  .instrument-sec{background:linear-gradient(175deg,var(--teal-deep),#0A3132); color:var(--bone); padding:60px 0; position:relative; overflow:hidden;}
.sigma-home .instrument-sec .eyebrow{color:var(--bronze-light);}
.sigma-home .instrument-sec .eyebrow::before{color:var(--bronze-light);}
.sigma-home .inst-grid{display:grid; grid-template-columns:0.82fr 1.18fr; gap:60px; align-items:center;}
.sigma-home .inst-copy h2{color:var(--bone); font-size:clamp(36px,4.4vw,56px); line-height:1.06; font-weight:300; margin:22px 0 24px; letter-spacing:-0.02em;}
.sigma-home .inst-copy h2 em{font-style:italic; color:var(--bronze-light);}
.sigma-home .inst-copy p{color:rgba(237,231,218,0.76); font-size:16.5px; line-height:1.68; max-width:420px;}
.sigma-home .inst-copy .hint{display:inline-flex; align-items:center; gap:9px; margin-top:26px; font-family:'IBM Plex Mono',monospace; font-size:11.5px; letter-spacing:0.05em; color:var(--bronze-light); text-transform:uppercase;}
.sigma-home .inst-copy .hint .arrow{animation:nudge 1.6s ease-in-out infinite;}
@keyframes nudge{0%,100%{transform:translateX(0);}50%{transform:translateX(5px);}}
@media (prefers-reduced-motion: reduce){.sigma-home .inst-copy .hint .arrow{animation:none;}}
.sigma-home .instrument{background:rgba(255,255,255,0.035); border:1px solid rgba(196,164,114,0.3); border-radius:8px; padding:26px 28px 24px;}
.sigma-home .inst-head{display:flex; justify-content:space-between; align-items:center; margin-bottom:6px; font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:0.08em; text-transform:uppercase; color:var(--bronze-light);}
.sigma-home .inst-head .live{display:flex; align-items:center; gap:7px; color:rgba(237,231,218,0.55);}
.sigma-home .inst-head .live .led{width:6px; height:6px; border-radius:50%; background:#8FD6A6; box-shadow:0 0 7px #8FD6A6;}
.sigma-home .inst-readouts{display:flex; gap:34px; align-items:flex-end; margin:14px 0 6px;}
.sigma-home .ro-block .ro-label{font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:0.06em; text-transform:uppercase; color:rgba(237,231,218,0.5); margin-bottom:4px;}
.sigma-home .ro-block .ro-val{font-family:'Fraunces',serif; font-weight:300; line-height:1; letter-spacing:-0.02em;}
.sigma-home .ro-block.age .ro-val{font-size:34px; color:var(--bone);}
.sigma-home .ro-block.nat .ro-val{font-size:44px; color:var(--bone);}
.sigma-home .ro-block.sup{display:none;}
.sigma-home .ro-block.sup .ro-val{font-size:44px; color:var(--bronze-light);}
.sigma-home .ro-block.delta{display:none; margin-left:auto; text-align:right;}
.sigma-home .ro-block.delta .ro-val{font-size:20px; color:#8FD6A6; font-family:'IBM Plex Mono',monospace; font-weight:500;}
.sigma-home .instrument.supported .ro-block.sup{display:block;}
.sigma-home .instrument.supported .ro-block.delta{display:block;}
.sigma-home .instrument.supported .ro-block.nat .ro-val{font-size:30px; color:rgba(237,231,218,0.55);}
.sigma-home .instrument.supported .ro-block.nat .ro-label{color:rgba(237,231,218,0.4);}
.sigma-home .inst-chart{position:relative; margin:8px 0 4px;}
.sigma-home .inst-chart svg{width:100%; height:auto; display:block;}
.sigma-home .grid-line{stroke:rgba(245,241,232,0.07);}
.sigma-home .axis-base{stroke:rgba(245,241,232,0.16);}
.sigma-home .curve-nat{fill:none; stroke:rgba(237,231,218,0.55); stroke-width:2.5; stroke-linecap:round;}
.sigma-home .curve-sup{fill:none; stroke:var(--bronze-light); stroke-width:2.5; stroke-linecap:round; opacity:0; transition:opacity .5s;}
.sigma-home .instrument.supported .curve-sup{opacity:1;}
.sigma-home .fill-gap{fill:rgba(196,164,114,0.1); opacity:0; transition:opacity .5s;}
.sigma-home .instrument.supported .fill-gap{opacity:1;}
.sigma-home .scan-line{stroke:rgba(196,164,114,0.5); stroke-width:1; stroke-dasharray:3 3;}
.sigma-home .dot-nat{fill:var(--bone);}
.sigma-home .dot-sup{fill:var(--bronze-light); opacity:0;}
.sigma-home .instrument.supported .dot-sup{opacity:1;}
.sigma-home .axis-txt{font-family:'IBM Plex Mono',monospace; font-size:9px; fill:rgba(237,231,218,0.42);}
.sigma-home .y-txt{font-family:'IBM Plex Mono',monospace; font-size:8.5px; fill:rgba(237,231,218,0.4);}
.sigma-home .inst-controls{margin-top:16px;}
.sigma-home .slider-row{display:flex; align-items:center; gap:16px;}
.sigma-home .slider-row .cap{font-family:'IBM Plex Mono',monospace; font-size:10px; color:rgba(237,231,218,0.4); letter-spacing:0.04em; min-width:26px;}
.sigma-home input[type=range].age-slider{-webkit-appearance:none; appearance:none; width:100%; height:2px; background:rgba(245,241,232,0.22); border-radius:2px; outline:none; cursor:pointer;}
.sigma-home input[type=range].age-slider::-webkit-slider-thumb{-webkit-appearance:none; appearance:none; width:20px; height:20px; border-radius:50%; background:var(--bronze-light); border:3px solid var(--teal-deep); box-shadow:0 0 0 1px var(--bronze-light); cursor:grab;}
.sigma-home input[type=range].age-slider::-webkit-slider-thumb:active{cursor:grabbing;}
.sigma-home input[type=range].age-slider::-moz-range-thumb{width:20px; height:20px; border-radius:50%; background:var(--bronze-light); border:3px solid var(--teal-deep); cursor:grab;}
.sigma-home .toggle-row{display:flex; justify-content:space-between; align-items:center; margin-top:22px; padding-top:20px; border-top:1px solid var(--line-light);}
.sigma-home .toggle-label{font-size:13.5px; color:rgba(237,231,218,0.8);}
.sigma-home .toggle-label span{font-family:'IBM Plex Mono',monospace; font-size:10px; color:rgba(237,231,218,0.45); display:block; margin-top:3px; text-transform:uppercase; letter-spacing:0.05em;}
.sigma-home .tgl{position:relative; width:52px; height:28px; background:rgba(245,241,232,0.15); border-radius:20px; cursor:pointer; transition:background .25s; flex-shrink:0; border:1px solid var(--line-light);}
.sigma-home .tgl::after{content:''; position:absolute; top:3px; left:3px; width:20px; height:20px; border-radius:50%; background:var(--bone); transition:transform .25s;}
.sigma-home .instrument.supported .tgl{background:var(--bronze);}
.sigma-home .instrument.supported .tgl::after{transform:translateX(24px);}
.sigma-home .inst-foot{font-family:'IBM Plex Mono',monospace; font-size:10px; color:rgba(237,231,218,0.38); line-height:1.6; margin-top:18px; letter-spacing:0.02em;}
@media(max-width:880px){.sigma-home .inst-grid{grid-template-columns:1fr; gap:40px;}
.sigma-home .inst-copy p{max-width:100%;}}
.sigma-home /* PHILOSOPHY BEAT */
  .philo{padding:60px 0; text-align:center;}
.sigma-home .philo .big{font-size:clamp(40px,6vw,80px); font-weight:300; line-height:1.02; letter-spacing:-0.03em; max-width:900px; margin:22px auto 26px;}
.sigma-home .philo .big em{font-style:italic; color:var(--teal-mid);}
.sigma-home .philo p{max-width:540px; margin:0 auto; font-size:17px; line-height:1.68; color:var(--ink-soft);}
.sigma-home /* MECHANISM */
  .mech{padding:0 0 60px;}
.sigma-home .section-head{max-width:600px; margin-bottom:60px;}
.sigma-home .section-head h2{font-size:clamp(30px,3.6vw,46px); line-height:1.1; font-weight:300; margin-top:20px; letter-spacing:-0.02em;}
.sigma-home .section-head p{font-size:16.5px; color:var(--ink-soft); margin-top:18px; line-height:1.62;}
.sigma-home .mech-row{display:grid; grid-template-columns:repeat(3,1fr); border-top:1px solid var(--line);}
.sigma-home .mech-card{padding:40px 34px 44px; border-right:1px solid var(--line); position:relative;}
.sigma-home .mech-card:last-child{border-right:none;}
.sigma-home .mech-card .idx{font-family:'IBM Plex Mono',monospace; font-size:11.5px; color:var(--bronze); margin-bottom:60px; letter-spacing:0.06em; display:block;}
.sigma-home .mech-card h3{font-size:23px; margin-bottom:14px; font-weight:400;}
.sigma-home .mech-card p{font-size:14.5px; color:var(--ink-soft); line-height:1.62;}
@media(max-width:880px){.sigma-home .mech-row{grid-template-columns:1fr;}
.sigma-home .mech-card{border-right:none; border-bottom:1px solid var(--line);}
.sigma-home .mech-card .idx{margin-bottom:22px;}}
.sigma-home /* FORMULA */
  .formula{background:var(--bone-light); border-top:1px solid var(--line); padding:60px 0;}
.sigma-home .readout{background:var(--teal-deep); border-radius:6px; overflow:hidden; border:1px solid rgba(196,164,114,0.25);}
.sigma-home .readout-top{display:flex; justify-content:space-between; align-items:center; padding:20px 30px; border-bottom:1px solid var(--line-light); font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:0.07em; color:var(--bronze-light); text-transform:uppercase;}
.sigma-home .readout-top .status{display:flex; align-items:center; gap:8px;}
.sigma-home .readout-top .status .led{width:6px; height:6px; border-radius:50%; background:var(--bronze-light); box-shadow:0 0 7px var(--bronze-light);}
.sigma-home .r-row{display:grid; grid-template-columns:2fr 1fr 0.7fr 1.5fr; gap:18px; align-items:center; padding:19px 30px; border-bottom:1px solid rgba(245,241,232,0.08);}
.sigma-home .r-row:last-of-type{border-bottom:none;}
.sigma-home .r-row .name{color:var(--bone); font-size:15px; font-weight:500;}
.sigma-home .r-row .dose{font-family:'IBM Plex Mono',monospace; color:var(--bronze-light); font-size:14px;}
.sigma-home .r-row .dv{font-family:'IBM Plex Mono',monospace; color:rgba(237,231,218,0.45); font-size:13px;}
.sigma-home .r-row .note{color:rgba(237,231,218,0.6); font-size:13px; line-height:1.5;}
.sigma-home .r-row.head{padding:14px 30px; font-family:'IBM Plex Mono',monospace; font-size:10px; text-transform:uppercase; letter-spacing:0.08em; color:rgba(237,231,218,0.4); border-bottom:1px solid var(--line-light);}
.sigma-home .readout-foot{padding:18px 30px; font-family:'IBM Plex Mono',monospace; font-size:11.5px; color:rgba(237,231,218,0.42); line-height:1.6;}
@media(max-width:700px){.sigma-home .r-row{grid-template-columns:1fr; gap:4px; padding:16px 22px;}
.sigma-home .r-row.head{display:none;}
.sigma-home .r-row .dose::before{content:'Per serving — '; color:rgba(237,231,218,0.4);}}
.sigma-home /* MISSION BEAT */
  .mission{padding:60px 0; border-top:1px solid var(--line);}
.sigma-home .mission-inner{display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center;}
.sigma-home .mission .loc{font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:0.08em; text-transform:uppercase; color:var(--bronze); display:flex; align-items:center; gap:9px; margin-bottom:22px;}
.sigma-home .mission .loc::before{content:'●'; font-size:7px;}
.sigma-home .mission h2{font-size:clamp(30px,3.6vw,44px); font-weight:300; line-height:1.1; letter-spacing:-0.02em; margin-bottom:20px;}
.sigma-home .mission p{font-size:16px; color:var(--ink-soft); line-height:1.66; margin-bottom:16px; max-width:460px;}
.sigma-home .cert-card{background:var(--teal-deep); border-radius:6px; padding:34px; color:var(--bone); border:1px solid rgba(196,164,114,0.25);}
.sigma-home .cert-card .cert-top{display:flex; justify-content:space-between; align-items:center; padding-bottom:20px; margin-bottom:20px; border-bottom:1px solid var(--line-light); font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:0.06em; text-transform:uppercase; color:var(--bronze-light);}
.sigma-home .cert-row{display:flex; justify-content:space-between; align-items:center; padding:12px 0; font-size:14px;}
.sigma-home .cert-row .k{color:rgba(237,231,218,0.6);}
.sigma-home .cert-row .v{font-family:'IBM Plex Mono',monospace; color:var(--bone); font-size:13.5px;}
.sigma-home .cert-row .v.pass{color:#8FD6A6;}
