<section class="closing">
  <div class="wrap">
    <h2 class="reveal">Give your cells back what <em>time takes away.</em></h2>
    <p class="reveal">NMN+ · 60 capsules · a 1-month supply.</p>
    <div class="reveal"><a href="/products/nmn-01" class="btn-primary">Shop NMN+</a></div>
  </div>
</section>

<script>
function initSigma(){
  var root=document.querySelector('.sigma-home');
  if(!root||root.dataset.sigmaInit) return;
  root.dataset.sigmaInit='1';
  root.classList.add('js-anim');
// reveal on scroll
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target);} });
  },{threshold:0.14});
  root.querySelectorAll('.reveal').forEach(el=>io.observe(el));

  // ---- Interactive NAD+ instrument ----
  (function(){
    const AGE_MIN=20, AGE_MAX=80;
    // plot geometry (must match SVG viewBox 620x300)
    const X0=56, X1=600, Y_TOP=40, Y_BOT=255;   // y_top=100%, y_bot=20%
    const PCT_HI=100, PCT_LO=20;
    const x = age => X0 + (age-AGE_MIN)/(AGE_MAX-AGE_MIN)*(X1-X0);
    const y = pct => Y_TOP + (PCT_HI-pct)/(PCT_HI-PCT_LO)*(Y_BOT-Y_TOP);
    // NAD+ natural decline model (% of age-20 peak)
    const nat = age => 28 + 72*Math.exp(-0.045*(age-AGE_MIN));
    // supported: precursor recovers ~45% of the lost ground (illustrative)
    const sup = age => { const n=nat(age); return n + (100-n)*0.45; };

    // build smooth paths by sampling
    function buildPath(fn){
      let d="";
      for(let a=AGE_MIN; a<=AGE_MAX; a+=1){
        d += (a===AGE_MIN?"M":"L") + x(a).toFixed(1) + "," + y(fn(a)).toFixed(1) + " ";
      }
      return d.trim();
    }
    const dNat=buildPath(nat), dSup=buildPath(sup);
    document.getElementById('curveNat').setAttribute('d', dNat);
    document.getElementById('curveSup').setAttribute('d', dSup);
    // fill between sup and nat
    let dFill="M";
    for(let a=AGE_MIN;a<=AGE_MAX;a+=1){ dFill += x(a).toFixed(1)+","+y(sup(a)).toFixed(1)+" L"; }
    for(let a=AGE_MAX;a>=AGE_MIN;a-=1){ dFill += x(a).toFixed(1)+","+y(nat(a)).toFixed(1)+" L"; }
    dFill = dFill.replace(/ L$/,"") + " Z";
    document.getElementById('fillGap').setAttribute('d', dFill);

    const slider=document.getElementById('ageSlider');
    const inst=document.getElementById('inst');
    const tgl=document.getElementById('tgl');
    const elAge=document.getElementById('roAge'), elNat=document.getElementById('roNat'),
          elSup=document.getElementById('roSup'), elDelta=document.getElementById('roDelta');
    const scan=document.getElementById('scan'), dotNat=document.getElementById('dotNat'), dotSup=document.getElementById('dotSup');

    function render(){
      const age=+slider.value;
      const n=nat(age), s=sup(age);
      const px=x(age);
      elAge.textContent=age;
      elNat.textContent=Math.round(n);
      elSup.textContent=Math.round(s);
      elDelta.textContent="+"+Math.round(s-n)+" pts";
      scan.setAttribute('x1',px); scan.setAttribute('x2',px);
      dotNat.setAttribute('cx',px); dotNat.setAttribute('cy',y(n));
      dotSup.setAttribute('cx',px); dotSup.setAttribute('cy',y(s));
    }
    function toggle(){
      const on=inst.classList.toggle('supported');
      tgl.setAttribute('aria-checked', on?'true':'false');
    }
    slider.addEventListener('input', render);
    tgl.addEventListener('click', toggle);
    tgl.addEventListener('keydown', e=>{ if(e.key===' '||e.key==='Enter'){e.preventDefault(); toggle();} });
    render();
  })();

  // ---- right scroll-progress rail (adaptive teal/beige, like the product page) ----
  (function(){
    var rail=root.querySelector('#homeRail');
    var railFill=root.querySelector('#homeRailFill');
    if(!rail) return;
    var nodes=[].slice.call(rail.querySelectorAll('.rail-node'));
    var targets=nodes.map(function(n){ return document.getElementById(n.getAttribute('data-target')); });
    var railTrack=rail.querySelector('.rail-track');
    var bands=[].slice.call(root.querySelectorAll('.hero,.thesis,.instrument-sec,.philo,.mech,.formula,.mission,.pricing,.faq,.closing,footer'));
    var current=-1;
    function bandInfo(el){
      if(!el) return {c:'#EDE7DA', dark:false};
      if(el.classList.contains('hero')||el.classList.contains('instrument-sec')||el.classList.contains('pricing')) return {c:'#0D3D3E', dark:true};
      if(el.tagName==='FOOTER') return {c:'#17302D', dark:true};
      if(el.classList.contains('thesis')||el.classList.contains('formula')||el.classList.contains('reviews')||el.classList.contains('closing')) return {c:'#F5F1E8', dark:false};
      return {c:'#EDE7DA', dark:false};
    }
    function bandAt(y){ for(var b=0;b<bands.length;b++){ var r=bands[b].getBoundingClientRect(); if(r.top<=y && r.bottom>=y) return bands[b]; } return null; }
    function segGrad(topY, botY, dim){
      var h=botY-topY; if(h<=1) return null;
      var segs=[];
      bands.forEach(function(b){ var r=b.getBoundingClientRect(); var t=Math.max(r.top,topY), bt=Math.min(r.bottom,botY); if(bt>t) segs.push({t:t,b:bt,d:bandInfo(b).dark}); });
      segs.sort(function(a,b){ return a.t-b.t; });
      if(!segs.length) return null;
      var parts=[];
      segs.forEach(function(s){
        var col = s.d ? (dim?'rgba(237,231,218,0.5)':'#EDE7DA') : (dim?'rgba(13,61,62,0.26)':'#0D3D3E');
        parts.push(col+' '+((s.t-topY)/h*100).toFixed(2)+'%', col+' '+((s.b-topY)/h*100).toFixed(2)+'%');
      });
      return 'linear-gradient(to bottom,'+parts.join(',')+')';
    }
    function paint(){
      var rr=rail.getBoundingClientRect(), lineTop=rr.top+28, lineBot=rr.bottom-28;
      var gt=segGrad(lineTop, lineBot, true); if(railTrack) railTrack.style.background = gt || 'rgba(13,61,62,0.22)';
      nodes.forEach(function(n){ var rn=n.querySelector('.rn'), rl=n.querySelector('.rl'), rnr=rn.getBoundingClientRect(), bi=bandInfo(bandAt(rnr.top+rnr.height/2)); n.classList.toggle('nd', bi.dark); if(rn) rn.style.background=bi.c; if(rl){ var lr=rl.getBoundingClientRect(), lb=bandInfo(bandAt(lr.top+lr.height/2)); rl.style.background=lb.c; rl.style.color=lb.dark?'#EDE7DA':'#0D3D3E'; } });
      if(railFill && nodes[current]){
        var nr=nodes[current].getBoundingClientRect(), activeY=nr.top+nr.height/2;
        railFill.style.height = Math.max(0, activeY-lineTop)+'px';
        railFill.style.background = segGrad(lineTop, activeY, false) || '#0D3D3E';
      }
    }
    function setActive(idx){ if(idx!==current){ current=idx; nodes.forEach(function(n,i){ n.classList.toggle('is-active', i===idx); }); } }
    var ticking=false;
    function onScroll(){ if(ticking) return; ticking=true; requestAnimationFrame(function(){ ticking=false; var mid=window.innerHeight*0.42, idx=0; targets.forEach(function(t,i){ if(t && t.getBoundingClientRect().top<=mid) idx=i; }); setActive(idx); paint(); }); }
    nodes.forEach(function(n,i){ n.addEventListener('click', function(){ if(targets[i]) targets[i].scrollIntoView({behavior:'smooth', block:'start'}); }); });
    window.addEventListener('scroll', onScroll, {passive:true});
    window.addEventListener('resize', function(){ current=-1; onScroll(); }, {passive:true});
    onScroll();
  })();
}
initSigma();
document.addEventListener('DOMContentLoaded', initSigma);
document.addEventListener('shopify:section:load', initSigma);
</script>
</div>

