<script>
function initSigma(){
  var root=document.querySelector('.sigma-home');
  if(!root||root.dataset.sigmaInit) return;
  root.dataset.sigmaInit='1';
  root.classList.add('js-anim');
// reveal on scroll
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target);} });
  },{threshold:0.14});
  root.querySelectorAll('.reveal').forEach(el=>io.observe(el));

  // ---- Interactive NAD+ instrument ----
  (function(){
    const AGE_MIN=20, AGE_MAX=80;
    // plot geometry (must match SVG viewBox 620x300)
    const X0=56, X1=600, Y_TOP=40, Y_BOT=255;   // y_top=100%, y_bot=20%
    const PCT_HI=100, PCT_LO=20;
    const x = age => X0 + (age-AGE_MIN)/(AGE_MAX-AGE_MIN)*(X1-X0);
    const y = pct => Y_TOP + (PCT_HI-pct)/(PCT_HI-PCT_LO)*(Y_BOT-Y_TOP);
    // NAD+ natural decline model (% of age-20 peak)
    const nat = age => 28 + 72*Math.exp(-0.045*(age-AGE_MIN));
    // supported: precursor recovers ~45% of the lost ground (illustrative)
    const sup = age => { const n=nat(age); return n + (100-n)*0.45; };

    // build smooth paths by sampling
    function buildPath(fn){
      let d="";
      for(let a=AGE_MIN; a<=AGE_MAX; a+=1){
        d += (a===AGE_MIN?"M":"L") + x(a).toFixed(1) + "," + y(fn(a)).toFixed(1) + " ";
      }
      return d.trim();
    }
    const dNat=buildPath(nat), dSup=buildPath(sup);
    document.getElementById('curveNat').setAttribute('d', dNat);
    document.getElementById('curveSup').setAttribute('d', dSup);
    // fill between sup and nat
    let dFill="M";
    for(let a=AGE_MIN;a<=AGE_MAX;a+=1){ dFill += x(a).toFixed(1)+","+y(sup(a)).toFixed(1)+" L"; }
    for(let a=AGE_MAX;a>=AGE_MIN;a-=1){ dFill += x(a).toFixed(1)+","+y(nat(a)).toFixed(1)+" L"; }
    dFill = dFill.replace(/ L$/,"") + " Z";
    document.getElementById('fillGap').setAttribute('d', dFill);

    const slider=document.getElementById('ageSlider');
    const inst=document.getElementById('inst');
    const tgl=document.getElementById('tgl');
    const elAge=document.getElementById('roAge'), elNat=document.getElementById('roNat'),
          elSup=document.getElementById('roSup'), elDelta=document.getElementById('roDelta');
    const scan=document.getElementById('scan'), dotNat=document.getElementById('dotNat'), dotSup=document.getElementById('dotSup');

    function render(){
      const age=+slider.value;
      const n=nat(age), s=sup(age);
      const px=x(age);
      elAge.textContent=age;
      elNat.textContent=Math.round(n);
      elSup.textContent=Math.round(s);
      elDelta.textContent="+"+Math.round(s-n)+" pts";
      scan.setAttribute('x1',px); scan.setAttribute('x2',px);
      dotNat.setAttribute('cx',px); dotNat.setAttribute('cy',y(n));
      dotSup.setAttribute('cx',px); dotSup.setAttribute('cy',y(s));
    }
    function toggle(){
      const on=inst.classList.toggle('supported');
      tgl.setAttribute('aria-checked', on?'true':'false');
    }
    slider.addEventListener('input', render);
    tgl.addEventListener('click', toggle);
    tgl.addEventListener('keydown', e=>{ if(e.key===' '||e.key==='Enter'){e.preventDefault(); toggle();} });
    render();
  })();
}
initSigma();
document.addEventListener('DOMContentLoaded', initSigma);
document.addEventListener('shopify:section:load', initSigma);
</script>
</div>

