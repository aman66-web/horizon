<div class="sigma-about-sec">
<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600&display=swap');
:root{--bone:#EDE7DA;--bone-light:#F5F1E8;--bone-card:#F7F4EC;--ink:#17302D;--ink-soft:rgba(23,48,45,.66);--ink-faint:rgba(23,48,45,.42);--teal-deep:#0D3D3E;--teal-mid:#3B7C77;--bronze:#A6844E;--bronze-light:#C4A472;--line:rgba(23,48,45,.14);--line-light:rgba(245,241,232,.16)}
.sigma-about-sec *{box-sizing:border-box;margin:0;padding:0}
.sigma-about-sec{scroll-behavior:smooth}
.sigma-about-sec{background:var(--bone);color:var(--ink);font-family:'Inter',sans-serif;-webkit-font-smoothing:antialiased;line-height:1.5;overflow-x:hidden}
.sigma-about-sec h1, .sigma-about-sec h2, .sigma-about-sec h3{font-family:'Fraunces',serif;font-weight:400;letter-spacing:-.015em}
.sigma-about-sec a{color:inherit;text-decoration:none}
.sigma-about-sec .wrap{max-width:1200px;margin:0 auto;padding:0 40px}
.sigma-about-sec .narrow{max-width:780px;margin:0 auto}
.sigma-about-sec .eyebrow{font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--bronze);display:inline-flex;align-items:center;gap:11px}
.sigma-about-sec .eyebrow::before{content:'●';font-size:7px;transform:translateY(-1px)}
.sigma-about-sec .reveal{opacity:0;transform:translateY(22px);transition:opacity .8s cubic-bezier(.2,.7,.2,1),transform .8s cubic-bezier(.2,.7,.2,1)}
.sigma-about-sec .reveal.in{opacity:1;transform:none}
@media(prefers-reduced-motion:reduce){.sigma-about-sec .reveal{opacity:1;transform:none;transition:none}
.sigma-about-sec{scroll-behavior:auto}}
.sigma-about-sec .hero{padding:120px 0 100px;text-align:center}
.sigma-about-sec .hero h1{font-size:clamp(44px,6vw,84px);line-height:1;font-weight:300;letter-spacing:-.03em;margin:26px auto 0;max-width:960px}
.sigma-about-sec .hero h1 em{font-style:italic;color:var(--teal-mid)}
.sigma-about-sec .manifesto{border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:var(--bone-light);padding:100px 0}
.sigma-about-sec .manifesto p{font-family:'Fraunces',serif;font-size:clamp(22px,2.6vw,32px);line-height:1.5;font-weight:300;letter-spacing:-.01em;color:var(--ink)}
.sigma-about-sec .manifesto p em{font-style:italic;color:var(--teal-mid)}
.sigma-about-sec .manifesto p+p{margin-top:26px}
.sigma-about-sec .chapter{padding:100px 0}
.sigma-about-sec .chapter.dark{background:linear-gradient(175deg,var(--teal-deep),#0A3132);color:var(--bone)}
.sigma-about-sec .chapter.dark .eyebrow{color:var(--bronze-light)}
.sigma-about-sec .chapter.dark h2{color:var(--bone)}
.sigma-about-sec .chapter.dark p{color:rgba(237,231,218,.76)}
.sigma-about-sec .chapter h2{font-size:clamp(30px,3.8vw,50px);line-height:1.08;font-weight:300;letter-spacing:-.022em;margin:20px 0 24px}
.sigma-about-sec .chapter h2 em{font-style:italic;color:var(--teal-mid)}
.sigma-about-sec .chapter.dark h2 em{color:var(--bronze-light)}
.sigma-about-sec .chapter p{font-size:17px;line-height:1.72;color:var(--ink-soft);margin-bottom:20px}
.sigma-about-sec .chapter p.lead{font-size:20px;color:var(--ink);line-height:1.6}
.sigma-about-sec .chapter.dark p.lead{color:var(--bone)}
.sigma-about-sec /* the mark */
.mark{display:grid;grid-template-columns:.8fr 1.2fr;gap:60px;align-items:center}
.sigma-about-sec .mark-vis{display:flex;align-items:center;justify-content:center}
.sigma-about-sec .mark-vis svg{width:100%;max-width:280px}
@media(max-width:820px){.sigma-about-sec .mark{grid-template-columns:1fr;gap:40px}}
.sigma-about-sec /* principles */
.principles{background:var(--bone-light);border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:100px 0}
.sigma-about-sec .sec-head{max-width:620px;margin-bottom:56px}
.sigma-about-sec .sec-head h2{font-size:clamp(30px,3.6vw,46px);line-height:1.1;font-weight:300;margin-top:18px;letter-spacing:-.02em}
.sigma-about-sec .sec-head p{font-size:16.5px;color:var(--ink-soft);margin-top:16px;line-height:1.62}
.sigma-about-sec .prin{border-top:1px solid var(--line)}
.sigma-about-sec .prin-row{display:grid;grid-template-columns:80px 1fr 1.4fr;gap:30px;padding:36px 0;border-bottom:1px solid var(--line);align-items:baseline}
.sigma-about-sec .prin-row .num{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--bronze);letter-spacing:.06em}
.sigma-about-sec .prin-row h3{font-size:24px;font-weight:400;letter-spacing:-.01em}
.sigma-about-sec .prin-row p{font-size:15px;color:var(--ink-soft);line-height:1.66;margin:0}
@media(max-width:760px){.sigma-about-sec .prin-row{grid-template-columns:1fr;gap:10px;padding:28px 0}}
.sigma-about-sec /* not-this */
.stance{padding:100px 0}
.sigma-about-sec .stance-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:44px}
.sigma-about-sec .sc{border-radius:6px;padding:32px 30px;border:1px solid var(--line)}
.sigma-about-sec .sc.no{background:var(--bone-card)}
.sigma-about-sec .sc.yes{background:var(--teal-deep);color:var(--bone);border-color:rgba(196,164,114,.3)}
.sigma-about-sec .sc .k{font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.07em;text-transform:uppercase;margin-bottom:18px;display:block}
.sigma-about-sec .sc.no .k{color:var(--ink-faint)}
.sigma-about-sec .sc.yes .k{color:var(--bronze-light)}
.sigma-about-sec .sc ul{list-style:none;display:flex;flex-direction:column;gap:14px}
.sigma-about-sec .sc li{font-size:15px;line-height:1.55;display:flex;gap:12px}
.sigma-about-sec .sc.no li{color:var(--ink-soft)}
.sigma-about-sec .sc.yes li{color:rgba(237,231,218,.85)}
.sigma-about-sec .sc li::before{font-family:'IBM Plex Mono',monospace;font-size:14px}
.sigma-about-sec .sc.no li::before{content:'✕';color:var(--ink-faint)}
.sigma-about-sec .sc.yes li::before{content:'✓';color:var(--bronze-light)}
@media(max-width:760px){.sigma-about-sec .stance-grid{grid-template-columns:1fr}}
.sigma-about-sec /* founder note */
.note{background:var(--bone-light);border-top:1px solid var(--line);padding:100px 0}
.sigma-about-sec .note-in{max-width:760px;margin:0 auto}
.sigma-about-sec .note blockquote{font-family:'Fraunces',serif;font-size:clamp(22px,2.6vw,30px);line-height:1.5;font-weight:300;letter-spacing:-.01em;margin-bottom:34px}
.sigma-about-sec .note blockquote em{font-style:italic;color:var(--teal-mid)}
.sigma-about-sec .sig{display:flex;align-items:center;gap:16px}
.sigma-about-sec .sig .avatar{width:52px;height:52px;border-radius:50%;background:var(--teal-deep);color:var(--bone);display:flex;align-items:center;justify-content:center;font-family:'Fraunces',serif;font-size:22px}
.sigma-about-sec .sig .who .n{font-size:15px;font-weight:600;color:var(--ink)}
.sigma-about-sec .sig .who .r{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.05em;margin-top:2px}
.sigma-about-sec .close{padding:120px 0;text-align:center}
.sigma-about-sec .close h2{font-size:clamp(34px,4.6vw,58px);font-weight:300;line-height:1.05;letter-spacing:-.025em;max-width:720px;margin:0 auto 20px}
.sigma-about-sec .close h2 em{font-style:italic;color:var(--teal-mid)}
.sigma-about-sec .close p{color:var(--ink-soft);font-size:16.5px;margin-bottom:34px}
.sigma-about-sec .btn{display:inline-block;background:var(--ink);color:var(--bone);padding:16px 32px;border-radius:2px;font-size:14.5px;font-weight:500;transition:background .2s}
.sigma-about-sec .btn:hover{background:var(--teal-deep)}
.sigma-about-sec .disc{padding:40px 0;border-top:1px solid var(--line);font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--ink-faint);text-align:center;line-height:1.7}
</style>

<section class="hero">
  <div class="wrap">
    <span class="eyebrow reveal">Our Story</span>
    <h1 class="reveal">We started Sigma because the supplement aisle has a <em>trust problem.</em></h1>
  </div>
</section>

<section class="manifesto">
  <div class="wrap narrow reveal">
    <p>Walk down any supplement aisle and you'll find bold promises, beautiful labels, and almost no way to verify a word of it.</p>
    <p>"Proprietary blends" that hide how little active ingredient is actually inside. Doses a fraction of what the research used. Purity claims no one ever checks. The whole category runs on <em>hope</em> — that the powder in the capsule is what the label says.</p>
    <p>We thought longevity — of all things — deserved better than hope.</p>
  </div>
</section>

<section class="chapter">
  <div class="wrap mark">
    <div class="mark-vis reveal">
      <svg viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="The Sigma mark">
        <circle cx="150" cy="150" r="120" fill="none" stroke="rgba(23,48,45,.14)" stroke-width="1"/>
        <text x="150" y="176" text-anchor="middle" font-family="Fraunces,serif" font-size="120" fill="#0D3D3E">σ</text>
        <text x="150" y="230" text-anchor="middle" font-family="IBM Plex Mono,monospace" font-size="11" letter-spacing="3" fill="#A6844E">SIGMA</text>
      </svg>
    </div>
    <div class="reveal">
      <span class="eyebrow">The Name</span>
      <h2>In statistics, sigma measures <em>consistency.</em></h2>
      <p class="lead">The σ symbol represents standard deviation — how much variation there is from the mean. Low sigma means tight, reliable, predictable.</p>
      <p>That's not an accident. It's the entire promise. Every batch dosed the same. Every claim measured, not asserted. Every jar the same as the last. In a category built on variance, we named ourselves after its opposite.</p>
    </div>
  </div>
</section>

<section class="principles">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">What We Stand On</span>
      <h2>Four principles. No exceptions.</h2>
    </div>
    <div class="prin reveal">
      <div class="prin-row">
        <span class="num">01</span>
        <h3>Disclose everything</h3>
        <p>Every ingredient, every dose, printed in full. No proprietary blends — ever. If it's in the capsule, it's on the label at the exact amount.</p>
      </div>
      <div class="prin-row">
        <span class="num">02</span>
        <h3>Dose to the research</h3>
        <p>We formulate to the levels used in published studies, not to whatever protects a margin. An underdosed active is just an expensive placebo.</p>
      </div>
      <div class="prin-row">
        <span class="num">03</span>
        <h3>Test every batch</h3>
        <p>Independent, third-party testing for purity, potency, and contaminants — on every production run. If a batch fails, it never ships. The report is public.</p>
      </div>
      <div class="prin-row">
        <span class="num">04</span>
        <h3>Claim only what's proven</h3>
        <p>We tell you what the science establishes, what's emerging, and what isn't known. We are not in the business of selling immortality.</p>
      </div>
    </div>
  </div>
</section>

<section class="stance">
  <div class="wrap narrow">
    <div class="sec-head reveal" style="margin-bottom:0">
      <span class="eyebrow">Plainly Put</span>
      <h2>What we are, and aren't.</h2>
    </div>
    <div class="stance-grid reveal">
      <div class="sc no">
        <span class="k">We are not</span>
        <ul>
          <li>A brand that promises to reverse aging</li>
          <li>Hiding doses behind a "blend"</li>
          <li>Asking you to just trust the label</li>
          <li>Making disease or cure claims</li>
        </ul>
      </div>
      <div class="sc yes">
        <span class="k">We are</span>
        <ul>
          <li>A precision-dosed NAD⁺ precursor, fully disclosed</li>
          <li>Third-party tested, every single batch</li>
          <li>Honest about what the evidence does and doesn't show</li>
          <li>Built for people who read the fine print</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="note">
  <div class="wrap note-in reveal">
    <span class="eyebrow" style="margin-bottom:24px">A Note From Us</span>
    <blockquote>"We built the company we wished existed when we started reading supplement labels ourselves — one that treats you like someone smart enough to want <em>proof,</em> not just promises."</blockquote>
    <div class="sig">
      <div class="avatar">σ</div>
      <div class="who">
        <div class="n">[Founder Name]</div>
        <div class="r">Founder, Sigma Formulas</div>
      </div>
    </div>
    <p style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--ink-faint);margin-top:28px;line-height:1.6">Replace with your real name and note before publishing. Keep it honest — this is the most personal page on the site.</p>
  </div>
</section>

<section class="close">
  <div class="wrap">
    <h2 class="reveal">Longevity, <em>measured.</em></h2>
    <p class="reveal">See the formula, read the lab report, and decide for yourself.</p>
    <div class="reveal"><a href="/pages/shop" class="btn">Shop NMN–01</a></div>
  </div>
</section>

<div class="disc"><div class="wrap">*These statements have not been evaluated by the FDA. This product is not intended to diagnose, treat, cure, or prevent any disease.</div></div>

<script>
const io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.14});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
</script>
</div>

