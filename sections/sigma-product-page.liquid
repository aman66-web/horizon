<script>
function initSigma(){
  var root=document.querySelector('.sigma-pdp');
  if(!root||root.dataset.sigmaInit) return;
  root.dataset.sigmaInit='1';
  root.classList.add('js-anim');
const io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}})},{threshold:.14});
  root.querySelectorAll('.reveal').forEach(el=>io.observe(el));

  // accordions
  document.querySelectorAll('.acc-q').forEach(q=>q.addEventListener('click',()=>q.parentElement.classList.toggle('open')));

  // plan selector
  const plans=document.querySelectorAll('.plan'), stickySub=document.getElementById('stickySub');
  plans.forEach(p=>p.addEventListener('click',()=>{
    plans.forEach(x=>x.classList.remove('sel'));
    p.classList.add('sel');
    stickySub.textContent = p.querySelector('.t').textContent.trim().replace(/Save 15%/,'').trim() + ' · ' + p.dataset.label;
  }));

  // capsule anatomy
  const layers=document.querySelectorAll('.layer');
  const bands={b1:document.getElementById('b1'),b2:document.getElementById('b2'),b3:document.getElementById('b3'),b4:document.getElementById('b4'),b5:document.getElementById('b5'),b6:document.getElementById('b6'),b7:document.getElementById('b7'),b8:document.getElementById('b8')};
  function focusBand(id){
    layers.forEach(l=>l.classList.toggle('on', l.dataset.band===id));
    Object.entries(bands).forEach(([k,el])=>{ if(el) el.classList.toggle('dim', k!==id); });
  }
  layers.forEach(l=>l.addEventListener('click',()=>focusBand(l.dataset.band)));
  Object.entries(bands).forEach(([k,el])=>{ if(el) el.addEventListener('click',()=>focusBand(k)); });
  focusBand('b1');

  // sticky bar after hero scrolled
  const buy=document.querySelector('.buy'), sticky=document.getElementById('sticky');
  new IntersectionObserver(es=>{ sticky.classList.toggle('show', !es[0].isIntersecting); },{threshold:0}).observe(buy);
}
initSigma();
document.addEventListener('DOMContentLoaded', initSigma);
document.addEventListener('shopify:section:load', initSigma);
</script>
</div>

