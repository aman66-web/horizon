  .sigma-nmn .snmn-frow .nm{font-weight:700;font-size:.97rem;}
  .sigma-nmn .snmn-frow .note{display:block;font-weight:400;font-size:.85rem;color:var(--ink-soft);margin-top:2px;}
  .sigma-nmn .snmn-frow .amt{white-space:nowrap;font-weight:600;color:var(--ink);}
  .sigma-nmn .snmn-other{padding:13px 0;font-size:.88rem;color:var(--ink-faint);border-bottom:1px solid var(--line);}
  .sigma-nmn details.snmn-acc{border-top:1px solid var(--line);padding:14px 0;}
  .sigma-nmn details.snmn-acc summary{cursor:pointer;display:flex;justify-content:space-between;gap:12px;font-weight:700;list-style:none;}
  .sigma-nmn details.snmn-acc summary::-webkit-details-marker{display:none;}
  .sigma-nmn details.snmn-acc summary .pm{color:var(--green);flex:none;}
  .sigma-nmn details.snmn-acc[open] summary .pm{transform:rotate(45deg);}
  .sigma-nmn details.snmn-acc p{margin:10px 0 0;font-size:.93rem;color:var(--ink-soft);}
  .sigma-nmn .snmn-pills{display:flex;flex-wrap:wrap;gap:10px;margin:26px 0 0;}
  .sigma-nmn .snmn-pill{border:1.5px solid var(--green);border-radius:999px;padding:6px 14px;font-size:.85rem;font-weight:600;color:var(--green);}
  /* ---- 4.5 comparison (centered, contained) ---- */
