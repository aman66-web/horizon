        <h1>{% if has_product %}{{ product.title | remove_first: 'NMN+' | strip }}{% else %}Daily Longevity{% endif %}</h1>
      </div>
    </div>

    <!-- LEFT: product gallery — swipe-across slider with clear arrow controls -->
