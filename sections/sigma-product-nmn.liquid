{%- liquid
  assign has_product = false
  if product and product.id
    assign has_product = true
  endif

  assign cdn = 'https://cdn.shopify.com/s/files/1/0816/0287/1534/files/'
  assign img_bottle_plain = cdn | append: 'NMN2_86516883-9db8-4011-bfd8-05cf8166aceb.png'
  assign img_glow = cdn | append: 'Generated_Image_July_12_2026_-_4_32PM_7dabcd09-2061-42be-a859-35162a2a45fb.jpg'
  assign img_hand = cdn | append: 'Generated_Image_July_12_2026_-_4_44PM_278c3c5a-b9e9-4dcf-9a1e-de608628d256.jpg'
  assign img_marble = cdn | append: 'Generated_Image_July_12_2026_-_4_48PM_f4e2df73-4307-470c-b9cf-a855918b7ea5.jpg'
  assign img_spill = cdn | append: 'Generated_Image_July_12_2026_-_5_14PM_ae87c2c1-d17a-4ff2-a148-f7e6f8da17bc.jpg'
  assign img_capsule = cdn | append: 'capsule-hero-clean_1c4f6903-61eb-4b67-954a-40dfe5264abb.png'

  # Subscription selling plan (10% off / monthly), if one is configured on the product.
  assign sub_plan_id = ''
  for grp in product.selling_plan_groups
    for sp in grp.selling_plans
      assign sub_plan_id = sp.id
      break
    endfor
    if sub_plan_id != blank
      break
    endif
  endfor

  assign sub_price = product.price | times: 0.9
-%}

<!-- ============ LEFT SCROLL-PROGRESS RAIL ============ -->
<nav class="pdp-rail" id="pdpRail" aria-label="Section progress">
  <span class="rail-track" aria-hidden="true"></span>
  <span class="rail-fill" id="railFill" aria-hidden="true"></span>
  <button class="rail-node is-active" type="button" data-target="nmn-top" aria-label="Overview"><span class="rn"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9.5 3h5v2.4l1.3 1.9c.5.8.7 1.6.7 2.5V19a2 2 0 0 1-2 2h-5a2 2 0 0 1-2-2V9.8c0-.9.2-1.7.7-2.5L9.5 5.4z"/><path d="M8.5 13h7"/></svg></span><span class="rl">Overview</span></button>
  <button class="rail-node" type="button" data-target="nmn-formula" aria-label="The formula"><span class="rn"><svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5.5" y="4.5" width="13" height="16" rx="2"/><path d="M9.5 3h5v3h-5z"/><path d="M8.8 11h6.4M8.8 14.3h6.4M8.8 17.6h3.8"/></svg></span><span class="rl">Formula</span></button>
  <button class="rail-node" type="button" data-target="proof" aria-label="The proof"><span class="rn"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 7.6-7 9-4-1.4-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg></span><span class="rl">Proof</span></button>
  <button class="rail-node" type="button" data-target="what-to-expect" aria-label="The ritual"><span class="rn"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="3.8"/><path d="M12 2.5v2M12 19.5v2M4.5 12h-2M21.5 12h-2M6.2 6.2 4.8 4.8M19.2 19.2l-1.4-1.4M17.8 6.2l1.4-1.4M4.8 19.2l1.4-1.4"/></svg></span><span class="rl">Ritual</span></button>
</nav>

<!-- ============ HERO ============ -->
