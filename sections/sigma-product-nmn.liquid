{%- if has_product -%}
<!-- STICKY MOBILE ADD-TO-CART BAR -->
<div class="buybar" id="pdpBuyBar" aria-hidden="true">
  <span class="bb-t">NMN+ — <span id="bbPrice">{{ sub_price | money }}</span><small>60 caps · 1-month supply</small></span>
  <button type="button" class="bb-cta" id="bbAtc"{% unless product.available %} disabled{% endunless %}>{% if product.available %}Add to Cart{% else %}Sold Out{% endif %}</button>
</div>
{%- endif -%}

<script>
(function(){
  function initPDP(){
    var root=document.querySelector('.sigma-pdp');
    if(!root||root.dataset.pdpInit) return;
    root.dataset.pdpInit='1';
    root.classList.add('js-anim');

    var io=new IntersectionObserver(function(es){
      es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
    },{threshold:0.12});
    // Reveal everything in (or just below) the first screen immediately so the
    // hero / buy box never loads blank; only animate sections further down.
    root.querySelectorAll('.reveal').forEach(function(el){
      if(el.getBoundingClientRect().top < window.innerHeight * 1.15){ el.classList.add('in'); }
      else { io.observe(el); }
    });

    // gallery swipe slider + dots
    var slider=root.querySelector('#galSlider');
    var dots=root.querySelectorAll('#galDots .dot');
    if(slider && dots.length){
      var step=function(){ var s=slider.querySelector('.slide'); return s ? s.getBoundingClientRect().width + 12 : slider.clientWidth; };
      var prevBtn=root.querySelector('#galPrev'), nextBtn=root.querySelector('#galNext');
      // prev arrow only appears after the first image; next arrow hides on the last.
      var updateArrows=function(i){
        if(prevBtn) prevBtn.classList.toggle('off', i<=0);
        if(nextBtn) nextBtn.classList.toggle('off', i>=dots.length-1);
      };
      var raf;
      slider.addEventListener('scroll', function(){
        if(raf) return;
        raf=requestAnimationFrame(function(){
          raf=null;
          var i=Math.round(slider.scrollLeft / step());
          if(i<0) i=0; if(i>dots.length-1) i=dots.length-1;
          dots.forEach(function(d,idx){ d.classList.toggle('active', idx===i); });
          updateArrows(i);
        });
      }, {passive:true});
      dots.forEach(function(d,idx){
        d.addEventListener('click', function(){ slider.scrollTo({ left: idx*step(), behavior:'smooth' }); });
      });
      var go=function(dir){
        var n=dots.length, cur=Math.round(slider.scrollLeft/step());
        var next=Math.max(0, Math.min(n-1, cur+dir));
        slider.scrollTo({ left: next*step(), behavior:'smooth' });
      };
      if(prevBtn) prevBtn.addEventListener('click', function(){ go(-1); });
      if(nextBtn) nextBtn.addEventListener('click', function(){ go(1); });
      updateArrows(0);
    }

    // frequency / subscription selector + bundle quantity stepper
    var freq=root.querySelector('.freq');
    var qtyWrap=root.querySelector('#qtyWrap');
    var qtyInput=root.querySelector('#qtyInput');
    var volMsg=root.querySelector('#volMsg');
    var ctaQty=root.querySelector('#ctaQty');
    var ctaPriceWrap=root.querySelector('#ctaPriceWrap');
    var qMinus=root.querySelector('#qMinus');
    var qPlus=root.querySelector('#qPlus');
    var TIERS={
      1:'Add one more to unlock <strong>5% off</strong>.',
      2:'<strong>5% off</strong> applied at checkout — add one more for 10%.',
      3:'<strong>10% off</strong> applied at checkout — add one more for 15%.'
    };
    function renderQty(){
      if(!qtyInput) return;
      var q=parseInt(qtyInput.value,10)||1;
      if(volMsg){
        if(q>=4){ volMsg.classList.add('maxed'); volMsg.innerHTML='Best value — <strong>15% off</strong> applied automatically at checkout.'; }
        else { volMsg.classList.remove('maxed'); volMsg.innerHTML=TIERS[q]; }
      }
      if(qMinus) qMinus.disabled = q<=1;
      if(ctaQty) ctaQty.textContent = q>1 ? (q+' ') : '';
      if(ctaPriceWrap) ctaPriceWrap.style.display = q>1 ? 'none' : '';
    }
    if(qPlus) qPlus.addEventListener('click', function(){ var q=parseInt(qtyInput.value,10)||1; if(q<6){ qtyInput.value=q+1; renderQty(); } });
    if(qMinus) qMinus.addEventListener('click', function(){ var q=parseInt(qtyInput.value,10)||1; if(q>1){ qtyInput.value=q-1; renderQty(); } });
    function syncQtyForFreq(isOnce){
      if(!qtyWrap) return;
      qtyWrap.hidden = !isOnce;
      if(!isOnce && qtyInput){ qtyInput.value=1; }
      renderQty();
    }
    if(freq){
      var opts=freq.querySelectorAll('.opt');
      var planInput=root.querySelector('#nmnSellingPlan');
      var ctaPrice=root.querySelector('#ctaPrice');
      opts.forEach(function(o){
        o.addEventListener('click', function(){
          opts.forEach(function(x){ x.classList.remove('selected'); var ri=x.querySelector('input'); if(ri) ri.checked=false; });
          o.classList.add('selected');
          var r=o.querySelector('input'); if(r) r.checked=true;
          if(planInput) planInput.value = o.getAttribute('data-selling-plan') || '';
          if(ctaPrice) ctaPrice.textContent = o.getAttribute('data-price') || '';
          syncQtyForFreq((r&&r.value)==='once');
        });
      });
    }

    // left scroll-progress rail
    var rail=root.querySelector('#pdpRail');
    var railFill=root.querySelector('#railFill');
    if(rail){
      var nodes=[].slice.call(rail.querySelectorAll('.rail-node'));
      var targets=nodes.map(function(n){ return document.getElementById(n.getAttribute('data-target')); });
      var current=-1;
      var bands=[].slice.call(root.querySelectorAll('.band, .hero'));
      var railTrack=rail.querySelector('.rail-track');
      function bandAt(y){
        for(var b=0;b<bands.length;b++){ var r=bands[b].getBoundingClientRect(); if(r.top<=y && r.bottom>=y) return bands[b]; }
        return null;
      }
      function bandColor(b){ return (b && b.classList.contains('green')) ? '#0D3D3E' : '#EDE7DA'; }
      // build a gradient so each part of the line contrasts the band it crosses
      function segGrad(topY, botY, dim){
        var h=botY-topY; if(h<=1) return null;
        var segs=[];
        bands.forEach(function(b){ var r=b.getBoundingClientRect(); var t=Math.max(r.top,topY), bt=Math.min(r.bottom,botY); if(bt>t) segs.push({t:t,b:bt,d:b.classList.contains('green')}); });
        segs.sort(function(a,b){ return a.t-b.t; });
        if(!segs.length) return null;
        var parts=[];
        segs.forEach(function(s){
          var col = s.d ? (dim?'rgba(237,231,218,0.5)':'#EDE7DA') : (dim?'rgba(13,61,62,0.26)':'#0D3D3E');
          parts.push(col+' '+((s.t-topY)/h*100).toFixed(2)+'%', col+' '+((s.b-topY)/h*100).toFixed(2)+'%');
        });
        return 'linear-gradient(to bottom,'+parts.join(',')+')';
      }
      function paint(){
        var rr=rail.getBoundingClientRect(), lineTop=rr.top+28, lineBot=rr.bottom-28;
        var gt=segGrad(lineTop, lineBot, true); if(railTrack) railTrack.style.background = gt || 'rgba(13,61,62,0.22)';
        nodes.forEach(function(n){ var rn=n.querySelector('.rn'), rl=n.querySelector('.rl'), rnr=rn.getBoundingClientRect(), b=bandAt(rnr.top+rnr.height/2); n.classList.toggle('nd', !!(b && b.classList.contains('green'))); if(rn) rn.style.background=bandColor(b); if(rl){ var lr=rl.getBoundingClientRect(), lb=bandAt(lr.top+lr.height/2), ld=!!(lb && lb.classList.contains('green')); rl.style.background=bandColor(lb); rl.style.color=ld?'#EDE7DA':'#0D3D3E'; } });
        if(railFill && nodes[current]){
          var nr=nodes[current].getBoundingClientRect(), activeY=nr.top+nr.height/2;
          railFill.style.height = Math.max(0, activeY-lineTop)+'px';
          railFill.style.background = segGrad(lineTop, activeY, false) || '#0D3D3E';
        }
      }
      function setActive(idx){
        if(idx!==current){ current=idx; nodes.forEach(function(n,i){ n.classList.toggle('is-active', i===idx); }); }
      }
      var ticking=false;
      function onScroll(){
        if(ticking) return; ticking=true;
        requestAnimationFrame(function(){
          ticking=false;
          var mid=window.innerHeight*0.42, idx=0;
          targets.forEach(function(t,i){ if(t && t.getBoundingClientRect().top<=mid) idx=i; });
          setActive(idx);
          paint();
        });
      }
      nodes.forEach(function(n,i){
        n.addEventListener('click', function(){ if(targets[i]) targets[i].scrollIntoView({behavior:'smooth', block:'start'}); });
      });
      window.addEventListener('scroll', onScroll, {passive:true});
      window.addEventListener('resize', function(){ current=-1; onScroll(); }, {passive:true});
      onScroll();
    }
  }
  function initBuyBar(){
    var bar=document.getElementById('pdpBuyBar');
    if(!bar||bar.dataset.init) return;
    bar.dataset.init='1';
    var buybox=document.querySelector('.sigma-pdp .buybox');
    var closing=document.querySelector('.sigma-pdp .closing');
    var realBtn=document.querySelector('#nmn-atc-hero button[name="add"]');
    var bbPrice=document.getElementById('bbPrice');
    var ctaPrice=document.getElementById('ctaPrice');
    document.getElementById('bbAtc').addEventListener('click', function(){
      if(realBtn && !realBtn.disabled){ realBtn.click(); }
      else if(buybox){ buybox.scrollIntoView({behavior:'smooth', block:'center'}); }
    });
    // mirror the buybox price when the frequency choice changes
    [].slice.call(document.querySelectorAll('input[name="nmn-freq"]')).forEach(function(r){
      r.addEventListener('change', function(){ setTimeout(function(){ if(ctaPrice&&bbPrice) bbPrice.textContent=ctaPrice.textContent; }, 0); });
    });
    if('IntersectionObserver' in window && buybox){
      var boxOut=false, endIn=false;
      function upd(){ var on=boxOut&&!endIn; bar.classList.toggle('on',on); bar.setAttribute('aria-hidden', on?'false':'true'); }
      new IntersectionObserver(function(es){ es.forEach(function(e){ boxOut=!e.isIntersecting; }); upd(); },{threshold:0.05}).observe(buybox);
      if(closing){ new IntersectionObserver(function(es){ es.forEach(function(e){ endIn=e.isIntersecting; }); upd(); },{threshold:0.05}).observe(closing); }
    }
  }
  // ---- Self-contained add-to-cart (bypasses theme component wiring) ----
  // The Horizon add-to-cart component was not reliably opening the drawer on
  // this custom section, so we own the whole flow: intercept the form submit,
  // POST to the Cart AJAX API, swap in the freshly rendered drawer section,
  // open it, and sync the header cart counts.
  var sgAdding = false;
  function sgOpenCartDrawer(){
    var tries = 0;
    (function attempt(){
      var drawer = document.getElementById('cart-drawer');
      if (drawer) {
        drawer.setAttribute('auto-open', '');
        try { if (typeof drawer.open === 'function') { drawer.open(); return; } } catch(e){}
        try { if (typeof drawer.showDialog === 'function') { drawer.showDialog(); return; } } catch(e){}
        var dlg = drawer.querySelector('dialog');
        if (dlg) {
          try { if (!dlg.open) dlg.showModal(); return; }
          catch(e){ dlg.setAttribute('open',''); return; }
        }
      }
      if (tries++ < 20) setTimeout(attempt, 50);
    })();
  }
  function sgRefreshCounts(){
    fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
      .then(function(r){ return r.json(); })
      .then(function(c){
        var n = c.item_count || 0;
        document.querySelectorAll('[data-sg-cart-count]').forEach(function(el){ el.textContent = n; });
        document.querySelectorAll('.cart-bubble__text-count').forEach(function(el){ el.textContent = n; });
        document.querySelectorAll('header-actions').forEach(function(h){ h.classList.toggle('sg-has-items', n > 0); });
        document.querySelectorAll('.cart-bubble').forEach(function(b){ if (n > 0) b.removeAttribute('hidden'); });
      })
      .catch(function(){});
  }
  function sgSubmitAdd(form){
    if (sgAdding) return;
    sgAdding = true;
    var btn = form.querySelector('button[name="add"]');
    var origHTML = btn ? btn.innerHTML : '';
    if (btn) { btn.disabled = true; btn.setAttribute('aria-busy', 'true'); }
    var errEl = form.querySelector('.product-form-text__error');
    if (errEl) { errEl.textContent = ''; errEl.classList.add('hidden'); }

    var fd = new FormData(form);
    if (!fd.get('selling_plan')) fd.delete('selling_plan');
    fd.append('sections', 'cart-drawer-section');
    fd.append('sections_url', window.location.pathname);

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
      body: fd
    })
      .then(function(res){ return res.json().then(function(data){ return { ok: res.ok, data: data }; }); })
      .then(function(r){
        if (!r.ok) throw r.data;
        if (r.data && r.data.sections && r.data.sections['cart-drawer-section']) {
          var host = document.getElementById('shopify-section-cart-drawer-section');
          if (host) host.innerHTML = r.data.sections['cart-drawer-section'];
        }
        sgRefreshCounts();
        sgOpenCartDrawer();
      })
      .catch(function(err){
        var msg = (err && err.description) || 'Sorry, this couldn’t be added. Please try again.';
        if (errEl) { errEl.textContent = msg; errEl.classList.remove('hidden'); }
        else { window.alert(msg); }
      })
      .then(function(){
        sgAdding = false;
        if (btn) { btn.disabled = false; btn.removeAttribute('aria-busy'); btn.innerHTML = origHTML; }
      });
  }
  function initAddToCart(){
    ['nmn-atc-hero', 'nmn-atc-closing'].forEach(function(id){
      var form = document.getElementById(id);
      if (!form || form.dataset.sgAtc) return;
      form.dataset.sgAtc = '1';
      form.addEventListener('submit', function(e){
        e.preventDefault();
        e.stopImmediatePropagation();
        sgSubmitAdd(form);
      }, true);
    });
  }

  initPDP(); initBuyBar(); initAddToCart();
  document.addEventListener('DOMContentLoaded', function(){ initPDP(); initBuyBar(); initAddToCart(); });
  document.addEventListener('shopify:section:load', function(){ initPDP(); initBuyBar(); initAddToCart(); });
})();
</script>
</div>

