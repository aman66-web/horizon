{%- comment -%}
  Sigma NMN+ — full-width, two-column Seed-style product page.
  Renders on the product.nmn template as the ONLY section, so it owns the
  whole page: a two-column hero (gallery + sticky buy box with a working
  add-to-cart form using the live product) followed by full-bleed
  alternating cream (#F7F5EC) / deep-teal (#0D3D3E) bands, with real
  product imagery woven through nearly every band (Seed-style).

  Design system reused from sections/sigma-homepage.liquid:
  Fraunces (headings, 300), Inter (body), IBM Plex Mono (labels);
  teal / bone / bronze / ink palette; scoped under .sigma-pdp.

  All copy is honest and preserved as-is: no reviews, no clinical trials,
  no invented kits or guarantees. Where research is referenced it points to
  NMN and its cofactors in general — not to this specific product.
{%- endcomment -%}

<div class="sigma-pdp">
<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600&display=swap');
.sigma-pdp{
  --bone:#EDE7DA; --cream:#F7F5EC; --cream-card:#ffffff;
  --ink:#17302D; --ink-soft:rgba(23,48,45,0.66); --ink-faint:rgba(23,48,45,0.42);
  --teal-deep:#0D3D3E; --teal:#14514F; --teal-mid:#3B7C77; --teal-frost:#D9E5E1;
  --green-band:#0D3D3E;
  --bronze:#A6844E; --bronze-light:#C4A472;
  --line:rgba(23,48,45,0.14); --line-light:rgba(245,241,232,0.16);
  --dark-fg:#EDE7DA; --dark-soft:rgba(237,231,218,0.72); --dark-faint:rgba(237,231,218,0.45);
}
.sigma-pdp *{box-sizing:border-box; margin:0; padding:0;}
.sigma-pdp{background:var(--bone); color:var(--ink); font-family:'Inter',sans-serif; -webkit-font-smoothing:antialiased; overflow-x:hidden; line-height:1.5;}
.sigma-pdp h1,.sigma-pdp h2,.sigma-pdp h3,.sigma-pdp h4{font-family:'Fraunces',serif; font-weight:400; letter-spacing:-0.015em; color:var(--ink);}
.sigma-pdp a{color:inherit; text-decoration:none;}
.sigma-pdp sup{font-size:0.58em; vertical-align:super; color:var(--bronze); font-family:'IBM Plex Mono',monospace;}
.sigma-pdp .wrap{max-width:1200px; margin:0 auto; padding:0 40px;}
.sigma-pdp .eyebrow{font-family:'IBM Plex Mono',monospace; font-size:11.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--bronze); display:inline-flex; align-items:center; gap:11px;}
.sigma-pdp .eyebrow::before{content:'●'; font-size:7px; transform:translateY(-1px);}
.sigma-pdp .sr{position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap;}

/* reveal on scroll */
.sigma-pdp .reveal{opacity:1; transform:none;}
.sigma-pdp.js-anim .reveal{opacity:0; transform:translateY(22px); transition:opacity .8s cubic-bezier(.2,.7,.2,1), transform .8s cubic-bezier(.2,.7,.2,1);}
.sigma-pdp.js-anim .reveal.in{opacity:1; transform:none;}
@media (prefers-reduced-motion: reduce){.sigma-pdp .reveal, .sigma-pdp.js-anim .reveal{opacity:1; transform:none; transition:none;}}

/* ---------- full-width bands ---------- */
.sigma-pdp .band{padding:56px 0;}
@media(max-width:700px){.sigma-pdp .band{padding:38px 0;}}
.sigma-pdp .band.cream{background:var(--cream); border-top:1px solid var(--line);}
.sigma-pdp .band.green{background:var(--green-band); color:var(--dark-fg);}
.sigma-pdp .band.green + .band.green{border-top:1px solid var(--line-light);}
.sigma-pdp .band.green h2,.sigma-pdp .band.green h3,.sigma-pdp .band.green h4{color:var(--dark-fg);}
.sigma-pdp .band.green .eyebrow{color:var(--bronze-light);}
.sigma-pdp .sec-head{max-width:680px; margin-bottom:50px;}
.sigma-pdp .sec-head.center{max-width:760px; margin-left:auto; margin-right:auto; text-align:center;}
.sigma-pdp .sec-head h2{font-size:clamp(30px,3.6vw,46px); line-height:1.1; font-weight:300; margin-top:18px; letter-spacing:-0.02em;}
.sigma-pdp .sec-head p{font-size:16.5px; color:var(--ink-soft); margin-top:16px; line-height:1.62;}
.sigma-pdp .band.green .sec-head p{color:var(--dark-soft);}

/* ---------- image + text bands (Seed-style) ---------- */
.sigma-pdp .imgband{display:grid; grid-template-columns:1fr 1fr; gap:56px; align-items:center;}
.sigma-pdp .imgband.rev .media{order:2;}                 /* image on the RIGHT on desktop */
.sigma-pdp .media{border-radius:16px; overflow:hidden; box-shadow:0 26px 54px -26px rgba(13,61,62,0.55); background:var(--cream);}
.sigma-pdp .media img{display:block; width:100%; height:100%; object-fit:cover; aspect-ratio:4/5; max-width:100%;}
.sigma-pdp .imgband .copy h2{font-size:clamp(28px,3.6vw,46px); font-weight:300; line-height:1.08; letter-spacing:-0.02em; margin:16px 0 18px;}
.sigma-pdp .imgband .copy h2 em{font-style:italic; color:var(--bronze-light);}
.sigma-pdp .band.cream .imgband .copy h2 em{color:var(--teal-mid);}
.sigma-pdp .imgband .copy p{font-size:16.5px; line-height:1.68; margin-bottom:14px;}
.sigma-pdp .band.green .imgband .copy p{color:var(--dark-soft);}
.sigma-pdp .band.cream .imgband .copy p{color:var(--ink-soft);}
@media(max-width:880px){
  .sigma-pdp .imgband{grid-template-columns:1fr; gap:30px;}
  .sigma-pdp .imgband.rev .media{order:0;}                /* image FIRST on mobile */
}

/* ---------- HERO ---------- */
.sigma-pdp .hero{padding:16px 0 44px;}
.sigma-pdp .hero-grid{display:grid; grid-template-columns:1.05fr 0.95fr; gap:64px; align-items:start;}
.sigma-pdp .gal-slider{display:flex; gap:12px; overflow-x:auto; scroll-snap-type:x mandatory; -webkit-overflow-scrolling:touch; scrollbar-width:none;}
.sigma-pdp .gal-slider::-webkit-scrollbar{display:none;}
.sigma-pdp .slide{flex:0 0 calc(100% - 36px); scroll-snap-align:start; aspect-ratio:1/1; border:1px solid var(--line); border-radius:16px; overflow:hidden; background:var(--cream);}
.sigma-pdp .slide:last-child{flex-basis:100%;}
.sigma-pdp .slide img{width:100%; height:100%; object-fit:cover; display:block;}
.sigma-pdp .gal-dots{display:flex; justify-content:center; gap:8px; margin-top:16px;}
.sigma-pdp .gal-dots .dot{width:8px; height:8px; padding:0; border:none; border-radius:100px; background:var(--line); cursor:pointer; transition:background .25s, width .25s;}
.sigma-pdp .gal-dots .dot.active{background:var(--teal-deep); width:22px;}
.sigma-pdp .buybox{position:sticky; top:20px;}
.sigma-pdp .title-row{display:flex; align-items:center; gap:13px; flex-wrap:wrap;}
.sigma-pdp .pill-badge{font-family:'Inter',sans-serif; font-size:13px; font-weight:500; color:var(--teal-deep); border:1.5px solid var(--teal-deep); border-radius:100px; padding:5px 15px; white-space:nowrap;}
.sigma-pdp .buybox h1{font-family:'Inter',sans-serif; font-size:clamp(30px,4.6vw,45px); line-height:1.04; font-weight:600; letter-spacing:-0.02em; color:var(--teal-deep); margin:0;}
.sigma-pdp .rating{display:flex; align-items:center; gap:12px; margin-top:16px;}
.sigma-pdp .rating .stars{color:var(--teal-deep); font-size:18px; letter-spacing:3px; line-height:1;}
.sigma-pdp .rating .rcount{font-size:15px; color:var(--teal-deep); font-weight:500; text-decoration:underline; text-underline-offset:3px;}
.sigma-pdp .buybox .desc{font-size:17px; line-height:1.5; color:var(--teal-deep); margin-top:22px; max-width:470px;}
.sigma-pdp .buybox .price-row{display:flex; align-items:center; gap:14px; margin-top:26px;}
.sigma-pdp .buybox .price{font-family:'Inter',sans-serif; font-size:33px; font-weight:600; color:var(--teal-deep); letter-spacing:-0.01em;}
.sigma-pdp .buybox .bestseller{background:#C9E88C; color:#0D3D3E; font-family:'Inter',sans-serif; font-size:14px; font-weight:500; border-radius:100px; padding:6px 16px;}
.sigma-pdp .buybox .subline{font-size:15px; line-height:1.5; color:var(--ink-soft); margin-top:14px; margin-bottom:26px;}
/* Frequency / subscription selector */
.sigma-pdp .freq{margin:26px 0 22px;}
.sigma-pdp .freq-label{font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-faint); margin-bottom:12px;}
.sigma-pdp .opt{display:grid; grid-template-columns:auto 1fr auto; align-items:center; gap:14px; border:1.5px solid var(--line); border-radius:14px; padding:18px 20px; cursor:pointer; position:relative; background:var(--cream-card); transition:border-color .2s, background .2s;}
.sigma-pdp .opt + .opt{margin-top:12px;}
.sigma-pdp .opt.selected{border-color:var(--teal-deep); background:rgba(201,232,140,0.16);}
.sigma-pdp .opt input{position:absolute; opacity:0; width:0; height:0; pointer-events:none;}
.sigma-pdp .opt .radio{width:20px; height:20px; border-radius:50%; border:1.5px solid var(--ink-faint); flex-shrink:0; position:relative;}
.sigma-pdp .opt.selected .radio{border-color:var(--teal-deep);}
.sigma-pdp .opt.selected .radio::after{content:''; position:absolute; inset:4px; border-radius:50%; background:var(--teal-deep);}
.sigma-pdp .opt-main .opt-t{font-size:16px; font-weight:600; color:var(--teal-deep);}
.sigma-pdp .opt-main .opt-s{font-size:13px; color:var(--ink-soft); margin-top:2px;}
.sigma-pdp .opt-p{text-align:right;}
.sigma-pdp .opt-p .now{font-size:17px; font-weight:600; color:var(--teal-deep);}
.sigma-pdp .opt-p .now .mo{font-size:12px; font-weight:500; color:var(--ink-soft);}
.sigma-pdp .opt-p .was{font-size:13px; color:var(--ink-faint); text-decoration:line-through;}
.sigma-pdp .opt-p .perday{font-size:11px; color:var(--ink-faint); margin-top:2px;}
.sigma-pdp .opt-benes{grid-column:1 / -1; display:none; flex-direction:column; gap:9px; margin-top:4px; padding-top:14px; border-top:1px solid var(--line);}
.sigma-pdp .opt.selected .opt-benes{display:flex;}
.sigma-pdp .opt-benes li{list-style:none; display:flex; gap:10px; align-items:center; font-size:13.5px; color:var(--teal-deep);}
.sigma-pdp .opt-benes li::before{content:'✓'; color:var(--teal-mid); font-size:12px;}
.sigma-pdp .save-pill{position:absolute; top:-10px; right:18px; background:#C9E88C; color:#0D3D3E; font-family:'Inter',sans-serif; font-size:11px; font-weight:600; border-radius:100px; padding:3px 11px;}
.sigma-pdp form.nmn-form{margin:0;}
.sigma-pdp product-form-component,.sigma-pdp add-to-cart-component{display:block;}
.sigma-pdp .product-form-text__error{display:block; margin-bottom:12px; font-family:'IBM Plex Mono',monospace; font-size:12px; color:#b23c3c;}
.sigma-pdp .product-form-text__error.hidden{display:none;}
.sigma-pdp .cta{display:block; width:100%; text-align:center; background:var(--ink); color:var(--bone); padding:18px; border-radius:100px; font-size:15px; font-weight:500; font-family:'Inter',sans-serif; border:none; cursor:pointer; transition:background .2s, transform .2s;}
.sigma-pdp .cta:hover{background:var(--teal-deep); transform:translateY(-1px);}
.sigma-pdp .cta:disabled{background:var(--ink-faint); cursor:not-allowed; transform:none;}
.sigma-pdp .trust{display:flex; flex-wrap:wrap; gap:8px; margin-top:16px;}
.sigma-pdp .tb{flex:1 1 calc(50% - 4px); display:flex; align-items:center; gap:8px; font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:0.04em; text-transform:uppercase; color:var(--ink-soft); border:1px solid var(--line); border-radius:100px; padding:9px 13px;}
.sigma-pdp .tb .d{flex-shrink:0; width:15px; height:15px; border-radius:50%; border:1.5px solid var(--teal-mid); color:var(--teal-mid); display:flex; align-items:center; justify-content:center; font-size:9px;}
.sigma-pdp .guarantee{text-align:center; font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--ink-faint); margin-top:14px; letter-spacing:0.03em;}
.sigma-pdp .checks{list-style:none; margin-top:30px; padding-top:26px; border-top:1px solid var(--line); display:flex; flex-direction:column; gap:14px;}
.sigma-pdp .checks .h{font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--bronze);}
.sigma-pdp .checks li{display:flex; gap:12px; font-size:14.5px; line-height:1.5; color:var(--ink);}
.sigma-pdp .checks li.hl{display:block;}
.sigma-pdp .checks li .tick{flex-shrink:0; width:19px; height:19px; border-radius:50%; border:1.5px solid var(--teal-mid); color:var(--teal-mid); display:flex; align-items:center; justify-content:center; font-size:11px; margin-top:1px;}
/* Buy-box accordion tabs (Benefits / Ingredients) */
.sigma-pdp .acc-tabs{margin-top:28px; border-top:1px solid var(--line);}
.sigma-pdp .tab{border-bottom:1px solid var(--line);}
.sigma-pdp .tab summary{list-style:none; cursor:pointer; display:flex; justify-content:space-between; align-items:center; gap:14px; padding:18px 0; font-size:16px; font-weight:600; color:var(--teal-deep);}
.sigma-pdp .tab summary::-webkit-details-marker{display:none;}
.sigma-pdp .tab summary .pm{font-family:'IBM Plex Mono',monospace; color:var(--teal-mid); font-size:20px; font-weight:400; transition:transform .22s;}
.sigma-pdp .tab[open] summary .pm{transform:rotate(45deg);}
.sigma-pdp .tab ul{list-style:none; padding:0 0 20px; display:flex; flex-direction:column; gap:11px;}
.sigma-pdp .tab-benes li{display:flex; gap:11px; font-size:14px; color:var(--ink-soft); line-height:1.5;}
.sigma-pdp .tab-benes li::before{content:'✓'; color:var(--teal-mid); flex-shrink:0;}
.sigma-pdp .tab-ings li{display:flex; justify-content:space-between; gap:16px; font-size:14px; color:var(--ink); border-bottom:1px solid var(--line); padding-bottom:10px;}
.sigma-pdp .tab-ings li:last-child{border-bottom:none; padding-bottom:0;}
.sigma-pdp .tab-ings .dose{font-family:'IBM Plex Mono',monospace; color:var(--bronze); white-space:nowrap;}
.sigma-pdp .tab-note{font-size:12.5px; color:var(--ink-faint); line-height:1.6; padding-bottom:20px;}
@media(max-width:880px){
  .sigma-pdp .hero-grid{grid-template-columns:1fr; gap:22px;}
  .sigma-pdp .buybox{position:static;}
}

/* ---------- BENEFIT TILES ---------- */
.sigma-pdp .bene-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:24px;}
.sigma-pdp .bene-card{background:var(--cream-card); border:1px solid var(--line); border-radius:12px; padding:30px 24px;}
.sigma-pdp .bene-card .ico{width:46px; height:46px; border-radius:50%; border:1.5px solid var(--bronze); display:flex; align-items:center; justify-content:center; margin-bottom:18px;}
.sigma-pdp .bene-card .ico svg{width:22px; height:22px; stroke:var(--bronze); fill:none; stroke-width:1.6; stroke-linecap:round; stroke-linejoin:round;}
.sigma-pdp .bene-card h3{font-size:18px; margin-bottom:8px; font-weight:400;}
.sigma-pdp .bene-card p{font-size:14px; color:var(--ink-soft); line-height:1.6;}
@media(max-width:980px){.sigma-pdp .bene-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:560px){.sigma-pdp .bene-grid{grid-template-columns:1fr;}}

/* ---------- MECHANISM (green) — capsule image + vertical steps ---------- */
.sigma-pdp .mech-band{border-top:1px solid var(--line-light);}
.sigma-pdp .capsule-anim-slot{min-height:0;}   /* reserved for future capsule animation */
.sigma-pdp .mech-list{display:flex; flex-direction:column; gap:26px;}
.sigma-pdp .mech-item{display:flex; gap:20px; align-items:flex-start;}
.sigma-pdp .mech-item .n{font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:0.06em; color:var(--bronze-light); white-space:nowrap; min-width:96px; padding-top:5px;}
.sigma-pdp .mech-item h3{font-size:20px; font-weight:400; margin-bottom:7px; color:var(--dark-fg);}
.sigma-pdp .mech-item p{font-size:14.5px; line-height:1.62; color:var(--dark-soft);}

/* ---------- TIMELINE (cream) — marble image + vertical steps ---------- */
.sigma-pdp .tl-list{display:flex; flex-direction:column; gap:22px; margin-top:26px;}
.sigma-pdp .tl-item .chip{display:inline-block; font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:0.06em; text-transform:uppercase; color:var(--bronze); border:1px solid var(--line); border-radius:100px; padding:5px 12px; margin-bottom:12px;}
.sigma-pdp .tl-item h3{font-size:19px; font-weight:400; margin-bottom:8px;}
.sigma-pdp .tl-item ul{list-style:none; display:flex; flex-direction:column; gap:8px;}
.sigma-pdp .tl-item li{font-size:14.5px; color:var(--ink-soft); line-height:1.55; display:flex; gap:10px;}
.sigma-pdp .tl-item li::before{content:'—'; color:var(--bronze); flex-shrink:0;}
.sigma-pdp .tl-item li.fine{color:var(--ink-faint); font-size:13px;}

/* ---------- FORMULA READOUT (green) — bottle image beside the list ---------- */
.sigma-pdp .facts{display:grid; grid-template-columns:1.3fr 0.7fr; gap:48px; align-items:start; margin-top:8px;}
.sigma-pdp .fx-ill{display:flex; flex-direction:column; gap:14px; text-align:center; position:sticky; top:30px;}
.sigma-pdp .fx-media{border-radius:16px; overflow:hidden; box-shadow:0 26px 54px -26px rgba(0,0,0,0.55);}
.sigma-pdp .fx-media img{display:block; width:100%; aspect-ratio:4/5; object-fit:cover; max-width:100%;}
.sigma-pdp .fx-ill .cap-name{font-family:'Fraunces',serif; font-size:18px; color:var(--dark-fg);}
.sigma-pdp .fx-ill .cap-sub{font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:0.05em; text-transform:uppercase; color:var(--bronze-light); margin-top:4px;}
.sigma-pdp .readout{border:1px solid rgba(196,164,114,0.25); border-radius:8px; overflow:hidden; background:rgba(0,0,0,0.16);}
.sigma-pdp .r-serve{padding:16px 26px; font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--dark-faint); border-bottom:1px solid var(--line-light); line-height:1.6;}
.sigma-pdp .frow{display:flex; justify-content:space-between; align-items:baseline; gap:18px; padding:16px 26px; border-bottom:1px solid rgba(245,241,232,0.08);}
.sigma-pdp .frow .nm{font-size:15px; font-weight:500; color:var(--dark-fg);}
.sigma-pdp .frow .note{display:block; font-weight:400; font-size:12.5px; color:var(--dark-soft); margin-top:4px; line-height:1.5; max-width:440px;}
.sigma-pdp .frow .amt{white-space:nowrap; font-family:'IBM Plex Mono',monospace; font-size:14px; color:var(--bronze-light);}
.sigma-pdp .r-other{padding:16px 26px; font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--dark-faint); line-height:1.6; border-bottom:1px solid rgba(245,241,232,0.08);}
.sigma-pdp details.acc{border-bottom:1px solid rgba(245,241,232,0.08); padding:0 26px;}
.sigma-pdp details.acc summary{cursor:pointer; display:flex; justify-content:space-between; gap:12px; font-family:'Fraunces',serif; font-size:16px; color:var(--dark-fg); list-style:none; padding:16px 0;}
.sigma-pdp details.acc summary::-webkit-details-marker{display:none;}
.sigma-pdp details.acc summary .pm{font-family:'IBM Plex Mono',monospace; color:var(--bronze-light); transition:transform .25s;}
.sigma-pdp details.acc[open] summary .pm{transform:rotate(45deg);}
.sigma-pdp details.acc p{font-size:13.5px; color:var(--dark-soft); line-height:1.65; padding:0 0 18px;}
.sigma-pdp .pills{display:flex; flex-wrap:wrap; gap:10px; margin-top:26px;}
.sigma-pdp .pill{border:1px solid rgba(196,164,114,0.4); border-radius:100px; padding:7px 15px; font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:0.05em; text-transform:uppercase; color:var(--bronze-light);}
@media(max-width:820px){.sigma-pdp .facts{grid-template-columns:1fr; gap:34px;}
  .sigma-pdp .fx-ill{position:static;}}
@media(max-width:560px){.sigma-pdp .frow{flex-direction:column; gap:4px;}}

/* ---------- COMPARISON ---------- */
.sigma-pdp .ctable{max-width:840px; margin:0 auto; border:1px solid var(--line); border-radius:10px; overflow:hidden; background:var(--cream-card);}
.sigma-pdp .crow{display:grid; grid-template-columns:1.9fr 0.8fr 0.8fr; align-items:center; border-bottom:1px solid var(--line);}
.sigma-pdp .crow:last-child{border-bottom:none;}
.sigma-pdp .crow.head{background:var(--teal-deep); color:var(--bone);}
.sigma-pdp .crow.head>div{padding:16px 22px; font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:0.08em; text-transform:uppercase;}
.sigma-pdp .crow.head .us{color:var(--bronze-light); font-weight:500; text-align:center;}
.sigma-pdp .crow.head .them{text-align:center;}
.sigma-pdp .crow>div{padding:16px 22px; font-size:14.5px;}
.sigma-pdp .crow .feat{color:var(--ink);}
.sigma-pdp .crow .us,.sigma-pdp .crow .them{text-align:center;}
.sigma-pdp .crow .mk-yes{display:inline-flex; align-items:center; justify-content:center; width:22px; height:22px; border-radius:50%; background:var(--teal-deep); color:var(--bone); font-size:12px;}
.sigma-pdp .crow .mk-no{display:inline-block; width:14px; height:2px; background:var(--ink-faint); vertical-align:middle;}
.sigma-pdp .cnote{max-width:840px; margin:18px auto 0; text-align:center; font-family:'IBM Plex Mono',monospace; font-size:11px; color:var(--ink-faint); line-height:1.6;}
@media(max-width:700px){.sigma-pdp .crow{grid-template-columns:1.6fr 0.7fr 0.7fr;}
