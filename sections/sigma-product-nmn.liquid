/* ===== Formula + Proof sections copied from the homepage ===== */
.sigma-pdp .section-head{max-width:600px; margin-bottom:40px;}
.sigma-pdp .section-head h2{font-size:clamp(30px,3.6vw,46px); line-height:1.1; font-weight:300; margin-top:20px; letter-spacing:-0.02em; color:var(--ink);}
