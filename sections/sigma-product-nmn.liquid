{%- liquid
  assign has_product = false
  if product and product.id
    assign has_product = true
  endif

  assign cdn = 'https://cdn.shopify.com/s/files/1/0816/0287/1534/files/'
  assign img_bottle_plain = cdn | append: 'NMN2_86516883-9db8-4011-bfd8-05cf8166aceb.png'
  assign img_glow = cdn | append: 'Generated_Image_July_12_2026_-_4_32PM_7dabcd09-2061-42be-a859-35162a2a45fb.jpg'
  assign img_hand = cdn | append: 'Generated_Image_July_12_2026_-_4_44PM_278c3c5a-b9e9-4dcf-9a1e-de608628d256.jpg'
  assign img_marble = cdn | append: 'Generated_Image_July_12_2026_-_4_48PM_f4e2df73-4307-470c-b9cf-a855918b7ea5.jpg'
  assign img_spill = cdn | append: 'Generated_Image_July_12_2026_-_5_14PM_ae87c2c1-d17a-4ff2-a148-f7e6f8da17bc.jpg'
  assign img_capsule = cdn | append: 'capsule-hero-clean_1c4f6903-61eb-4b67-954a-40dfe5264abb.png'

  # Subscription selling plan (10% off / monthly), if one is configured on the product.
  assign sub_plan_id = ''
  for grp in product.selling_plan_groups
    for sp in grp.selling_plans
      assign sub_plan_id = sp.id
      break
    endfor
    if sub_plan_id != blank
      break
    endif
  endfor

  assign sub_price = product.price | times: 0.9
-%}

<!-- ============ HERO ============ -->
<section class="hero" id="nmn-top">
  <div class="wrap hero-grid">

    <!-- LEFT: product gallery — swipe-across slider (front glow → hand → spill → capsule → marble) -->
    <div class="gallery reveal">
      <div class="gal-slider" id="galSlider">
        <div class="slide"><img src="{{ img_bottle_plain }}?width=1100" alt="NMN+ Daily Longevity bottle, front view" loading="eager" width="1100" height="1100"></div>
        <div class="slide"><img src="{{ img_glow }}?width=1100" alt="NMN+ bottle with a warm glow" loading="lazy" width="1100" height="1100"></div>
        <div class="slide"><img src="{{ img_hand }}?width=1100" alt="Hand holding the NMN+ bottle" loading="lazy" width="1100" height="1100"></div>
        <div class="slide"><img src="{{ img_spill }}?width=1100" alt="NMN+ capsules spilling from the bottle" loading="lazy" width="1100" height="1100"></div>
        <div class="slide"><img src="{{ img_capsule }}?width=1100" alt="A single NMN+ capsule on a dark background" loading="lazy" width="1100" height="1100"></div>
        <div class="slide"><img src="{{ img_marble }}?width=1100" alt="NMN+ on a sunlit marble counter with a glass of water" loading="lazy" width="1100" height="1100"></div>
      </div>
      <div class="gal-dots" id="galDots">
        <button type="button" class="dot active" aria-label="Go to image 1"></button>
        <button type="button" class="dot" aria-label="Go to image 2"></button>
        <button type="button" class="dot" aria-label="Go to image 3"></button>
        <button type="button" class="dot" aria-label="Go to image 4"></button>
        <button type="button" class="dot" aria-label="Go to image 5"></button>
        <button type="button" class="dot" aria-label="Go to image 6"></button>
      </div>
    </div>

    <!-- RIGHT: sticky buy box -->
    <div class="buybox reveal">
      <div class="title-row">
        <span class="pill-badge">NMN+</span>
        <h1>{% if has_product %}{{ product.title | remove_first: 'NMN+' | strip }}{% else %}Daily Longevity{% endif %}</h1>
      </div>

      <div class="rating" id="nmn-reviews">
        <span class="stars" aria-hidden="true">★★★★★</span>
        <a href="#nmn-reviews" class="rcount">1473 Reviews</a>
      </div>

      <p class="desc">A daily NAD⁺ precursor — seven fully disclosed actives, each dosed to the levels used in published research, with every ingredient printed on the label.*</p>

      <div class="freq">
        <div class="freq-label">Frequency</div>
        <label class="opt selected" data-selling-plan="{{ sub_plan_id }}" data-price="{{ sub_price | money }}">
          <input type="radio" name="nmn-freq" value="sub" checked>
          <span class="radio"></span>
          <div class="opt-main">
            <div class="opt-t">Subscribe &amp; Save</div>
            <div class="opt-s">Delivery every 30 days</div>
          </div>
          <div class="opt-p">
            <div class="now">{{ sub_price | money }}<span class="mo">/mo</span></div>
            <div class="was">{{ product.price | money }}</div>
            <div class="perday">{{ sub_price | divided_by: 30.0 | money }} per day</div>
          </div>
          <ul class="opt-benes">
            <li>Best price — save 10% on every order</li>
            <li>Delivered every 30 days</li>
            <li>Pause, skip, or cancel anytime</li>
            <li>Never run out</li>
          </ul>
          <span class="save-pill">Save 10%</span>
        </label>
        <label class="opt" data-selling-plan="" data-price="{{ product.price | money }}">
          <input type="radio" name="nmn-freq" value="once">
          <span class="radio"></span>
          <div class="opt-main">
            <div class="opt-t">Buy Once</div>
            <div class="opt-s">One-time purchase</div>
          </div>
          <div class="opt-p">
            <div class="now">{{ product.price | money }}</div>
            <div class="perday">{{ product.price | divided_by: 30.0 | money }} per day</div>
          </div>
        </label>
      </div>

      {%- if has_product -%}
        <product-form-component
          id="nmn-pf-hero"
          data-section-id="{{ section.id }}"
          data-product-id="{{ product.id }}"
          data-product-url="{{ product.url }}"
          on:submit="/handleSubmit"
          data-quantity-default="1"
        >
          <div class="visually-hidden" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
          {%- form 'product', product, id: 'nmn-atc-hero', data-type: 'add-to-cart-form', class: 'nmn-form' -%}
            <input type="hidden" name="id" ref="variantId" value="{{ product.selected_or_first_available_variant.id }}">
            <input type="hidden" name="selling_plan" id="nmnSellingPlan" value="{{ sub_plan_id }}">
            <span class="product-form-text__error hidden" ref="addToCartTextError"></span>
            <add-to-cart-component ref="addToCartButtonContainer" data-add-to-cart-animation="false">
              <button type="submit" name="add" class="cta" ref="addToCartButton" on:click="/handleClick"{% unless product.available %} disabled{% endunless %}>
                {% if product.available %}Add to Cart — <span id="ctaPrice">{{ sub_price | money }}</span>{% else %}Sold Out{% endif %}
              </button>
            </add-to-cart-component>
          {%- endform -%}
        </product-form-component>
      {%- else -%}
        <button type="button" class="cta">Add to Cart</button>
      {%- endif -%}

      <div class="trust">
        <div class="tb"><span class="d">✓</span>Third-Party Tested</div>
        <div class="tb"><span class="d">✓</span>Vegan HPMC</div>
        <div class="tb"><span class="d">✓</span>Non-GMO</div>
        <div class="tb"><span class="d">✓</span>No Fillers</div>
      </div>
      <div class="guarantee">Free US shipping over $60 · Cancel anytime</div>

      <div class="acc-tabs">
        <details class="tab" open>
          <summary>Benefits<sup>*</sup> <span class="pm" aria-hidden="true">+</span></summary>
          <ul class="tab-benes">
            <li>Supports your body’s NAD⁺ — a coenzyme central to cellular energy.*</li>
            <li>Every ingredient disclosed in full — no proprietary blends.</li>
            <li>Dosed to the levels used in published NMN research.</li>
            <li>No hidden fillers — nothing you can’t see on the label.</li>
          </ul>
        </details>
        <details class="tab">
          <summary>Ingredients <span class="pm" aria-hidden="true">+</span></summary>
          <ul class="tab-ings">
            <li><span>Nicotinamide Mononucleotide (NMN)</span><span class="dose">500 mg</span></li>
            <li><span>Trans-Resveratrol</span><span class="dose">150 mg</span></li>
            <li><span>Quercetin</span><span class="dose">100 mg</span></li>
            <li><span>Vitamin B6 (as Pyridoxal-5-Phosphate)</span><span class="dose">20 mg</span></li>
            <li><span>Vitamin B12 (as Methylcobalamin)</span><span class="dose">400 mcg</span></li>
            <li><span>Folate (as L-Methylfolate)</span><span class="dose">400 mcg DFE</span></li>
            <li><span>Black Pepper Extract (BioPerine)</span><span class="dose">5 mg</span></li>
          </ul>
          <p class="tab-note">Other Ingredients: Microcrystalline Cellulose, Magnesium Stearate, Silicon Dioxide, Hypromellose (Vegetable Capsule). Every dose is printed in full on the label.</p>
        </details>
      </div>
    </div>
  </div>
</section>

