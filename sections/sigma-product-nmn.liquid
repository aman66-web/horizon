{%- comment -%}
  Sigma NMN+ product story — full-width, edge-to-edge bands (Seed-style).
  Content moved out of the product description field into a proper theme section.
  All copy preserved verbatim. Bands break out of the theme container via the
  100vw + margin-inline calc technique; content is constrained to ~1200px.
{%- endcomment -%}

<div class="sigma-nmn">
<style>
  .sigma-nmn{--cream:#F7F5EC;--white:#ffffff;--ink:#1B2921;--ink-soft:#4C5A4C;--ink-faint:#5C6E5C;--green:#2c4a2e;--green-2:#47614B;--green-3:#8BA283;--line:#DDD9C9;--dark:#1B2921;--dark-fg:#F6F4EA;--dark-soft:#cdd8c8;--dark-faint:#a8bfa0;font-family:inherit;color:var(--ink);line-height:1.6;}
  .sigma-nmn *{box-sizing:border-box;}
  /* full-bleed band: break out of the theme's content container, edge to edge */
  .sigma-nmn .snmn-band{width:100vw;margin-inline-start:calc(50% - 50vw);}
  .sigma-nmn .snmn-inner{max-width:1200px;margin-inline:auto;padding:72px 32px;}
  .sigma-nmn .cream{background:var(--cream);color:var(--ink);}
  .sigma-nmn .dark{background:var(--dark);color:var(--dark-fg);}
  .sigma-nmn h2{font-size:clamp(1.5rem,3.2vw,2.1rem);line-height:1.16;letter-spacing:-.01em;margin:0 0 12px;color:var(--ink);}
  .sigma-nmn .dark h2{color:var(--dark-fg);}
  .sigma-nmn p{margin:0 0 10px;}
  .sigma-nmn sup{font-size:.66em;line-height:0;}
  .sigma-nmn .lede{color:var(--ink-faint);margin:0 0 26px;font-size:.98rem;}
  .sigma-nmn .dark .lede{color:var(--dark-soft);}
  /* ---- benefits strip ---- */
  .sigma-nmn .snmn-benefits-title{font-weight:700;margin:0 0 14px;}
  .sigma-nmn .snmn-checks{list-style:none;margin:0;padding:0;display:grid;gap:10px;max-width:760px;}
  .sigma-nmn .snmn-checks li{display:flex;gap:12px;align-items:flex-start;}
  .sigma-nmn .snmn-checks .ck{color:var(--green);font-weight:700;flex:none;}
  /* ---- 4 benefit tiles ---- */
  .sigma-nmn .snmn-tiles{display:grid;grid-template-columns:repeat(4,1fr);gap:26px;}
  .sigma-nmn .snmn-ico{width:46px;height:46px;border:1.5px solid var(--green);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:14px;}
  .sigma-nmn .snmn-ico svg{width:22px;height:22px;stroke:var(--green);fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;}
  .sigma-nmn .snmn-tiles h3{font-size:1rem;font-weight:700;margin:0 0 4px;}
  .sigma-nmn .snmn-tiles p{margin:0;font-size:.92rem;color:var(--ink-soft);}
  /* ---- split (dark science + standards) ---- */
  .sigma-nmn .snmn-split{display:flex;flex-wrap:wrap;gap:32px;align-items:center;}
  .sigma-nmn .snmn-split .col-main{flex:1 1 320px;min-width:260px;}
  .sigma-nmn .snmn-split .col-side{flex:1 1 230px;min-width:200px;}
  .sigma-nmn .snmn-capfig{display:flex;flex-direction:column;align-items:center;gap:14px;}
  .sigma-nmn .snmn-capfig svg{width:64px;height:auto;}
  .sigma-nmn .snmn-capfig .cap-name{margin:0 0 2px;font-weight:700;font-size:.95rem;color:var(--dark-fg);text-align:center;}
  .sigma-nmn .snmn-capfig .cap-sub{margin:0;font-size:.85rem;color:var(--dark-faint);text-align:center;}
  /* ---- timeline ---- */
  .sigma-nmn .snmn-timeline{border-inline-start:2px solid var(--green);padding-inline-start:24px;max-width:680px;display:grid;gap:22px;}
  .sigma-nmn .snmn-step{position:relative;}
  .sigma-nmn .snmn-step .dot{position:absolute;inset-inline-start:-30px;top:5px;width:11px;height:11px;border-radius:50%;background:var(--green);}
  .sigma-nmn .snmn-step.s2 .dot{background:var(--green-2);}
  .sigma-nmn .snmn-step.s3 .dot{background:var(--green-3);}
  .sigma-nmn .snmn-step .hd{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin:0 0 6px;}
  .sigma-nmn .snmn-chip{background:var(--dark);color:var(--dark-fg);border-radius:999px;padding:4px 12px;font-size:.8rem;font-weight:700;}
  .sigma-nmn .snmn-step.s2 .snmn-chip{background:var(--green-2);}
  .sigma-nmn .snmn-step.s3 .snmn-chip{background:var(--green-3);color:var(--ink);}
  .sigma-nmn .snmn-step ul{margin:0;padding-inline-start:18px;color:var(--ink-soft);font-size:.95rem;}
  .sigma-nmn .snmn-step ul .fine{font-size:.9em;color:var(--ink-faint);}
  /* ---- ingredient disclosure ---- */
  .sigma-nmn .snmn-disc-head{display:flex;flex-wrap:wrap;gap:8px;align-items:baseline;justify-content:space-between;margin:0 0 14px;}
  .sigma-nmn .snmn-disc-head p{margin:0;font-size:.9rem;color:var(--ink-faint);}
  .sigma-nmn details.snmn-acc{border-top:1px solid var(--line);padding:14px 0;}
  .sigma-nmn details.snmn-acc + details.snmn-acc{border-bottom:1px solid var(--line);}
  .sigma-nmn details.snmn-acc summary{cursor:pointer;display:flex;justify-content:space-between;gap:12px;font-weight:700;list-style:none;}
  .sigma-nmn details.snmn-acc summary::-webkit-details-marker{display:none;}
  .sigma-nmn details.snmn-acc summary .pm{color:var(--green);}
  .sigma-nmn details.snmn-acc[open] summary .pm{transform:rotate(45deg);}
  .sigma-nmn details.snmn-acc p{margin:10px 0 0;font-size:.93rem;color:var(--ink-soft);}
  .sigma-nmn .snmn-pills{display:flex;flex-wrap:wrap;gap:10px;margin:20px 0 0;}
  .sigma-nmn .snmn-pill{border:1.5px solid var(--green);border-radius:999px;padding:6px 14px;font-size:.85rem;font-weight:600;color:var(--green);}
  /* ---- comparison table ---- */
  .sigma-nmn .snmn-cmp{display:flex;flex-wrap:wrap;gap:24px;align-items:flex-start;}
  .sigma-nmn .snmn-cmp h2{flex:0 1 240px;min-width:180px;margin:0;}
  .sigma-nmn .snmn-table{flex:1 1 360px;min-width:0;background:rgba(246,244,234,.06);border:1px solid rgba(246,244,234,.15);border-radius:16px;padding:8px 22px 16px;}
  .sigma-nmn .snmn-trow{display:flex;gap:10px;align-items:center;padding:13px 0;border-bottom:1px solid rgba(246,244,234,.12);font-size:.92rem;}
  .sigma-nmn .snmn-trow:last-child{border-bottom:none;}
  .sigma-nmn .snmn-trow.head{font-size:.8rem;color:var(--dark-faint);padding:12px 0;}
  .sigma-nmn .snmn-trow .feat{flex:1;}
  .sigma-nmn .snmn-trow .col{flex:0 0 74px;text-align:center;}
  .sigma-nmn .snmn-trow.head .col.us{border:1px solid var(--dark-faint);border-radius:999px;padding:2px 0;}
  .sigma-nmn .snmn-yes,.sigma-nmn .snmn-no{display:inline-block;width:11px;height:11px;border-radius:50%;}
  .sigma-nmn .snmn-yes{background:var(--green-3);}
  .sigma-nmn .snmn-no{border:1.5px solid rgba(246,244,234,.45);}
  .sigma-nmn .sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;}
  .sigma-nmn .snmn-note{margin:16px 0 0;font-size:.78rem;color:var(--dark-faint);}
  /* ---- simply delivered cards ---- */
  .sigma-nmn .snmn-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;}
  .sigma-nmn .snmn-card{background:var(--white);border-radius:16px;padding:24px;}
  .sigma-nmn .snmn-card h3{font-weight:700;margin:0 0 4px;font-size:1rem;}
  .sigma-nmn .snmn-card .sub{margin:0 0 12px;font-size:.9rem;color:var(--ink-faint);}
  .sigma-nmn .snmn-kv{border-top:1px solid var(--line);padding:10px 0;display:flex;justify-content:space-between;gap:10px;font-size:.93rem;}
  .sigma-nmn .snmn-kv .k{font-weight:600;}
  .sigma-nmn .snmn-kv .v{color:var(--ink-faint);}
  /* ---- standards cards ---- */
  .sigma-nmn .snmn-std{display:flex;flex-wrap:wrap;gap:12px;flex:2 1 340px;min-width:240px;}
  .sigma-nmn .snmn-std .card{flex:1 1 150px;background:var(--white);border-radius:16px;padding:18px;font-size:.88rem;color:var(--green);font-weight:600;text-align:center;display:flex;align-items:center;justify-content:center;}
  /* ---- FDA disclaimer ---- */
  .sigma-nmn .snmn-fda{max-width:1200px;margin-inline:auto;padding:26px 32px;font-size:.8rem;color:var(--ink-faint);font-style:italic;}
  /* ---- responsive ---- */
  @media (max-width:980px){
    .sigma-nmn .snmn-tiles{grid-template-columns:repeat(2,1fr);}
  }
  @media (max-width:640px){
    .sigma-nmn .snmn-inner{padding:52px 20px;}
    .sigma-nmn .snmn-tiles,.sigma-nmn .snmn-cards{grid-template-columns:1fr;}
    .sigma-nmn .snmn-std .card{flex:1 1 100%;}
  }
</style>

