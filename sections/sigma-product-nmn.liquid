.sigma-pdp .tested-grid .t .ring{width:46px; height:46px; border-radius:50%; border:1.5px solid var(--bronze-light); color:var(--bronze-light); display:flex; align-items:center; justify-content:center; font-size:16px;}
.sigma-pdp .tested-grid .t span{font-size:12.5px; color:var(--dark-soft); line-height:1.4;}
