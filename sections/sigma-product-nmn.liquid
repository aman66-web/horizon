  .sigma-nmn .snmn-trow:last-child{border-bottom:none;}
  .sigma-nmn .snmn-trow.head{font-size:.8rem;color:var(--dark-faint);padding:12px 0;}
  .sigma-nmn .snmn-trow .feat{flex:1;}
  .sigma-nmn .snmn-trow .col{flex:0 0 84px;text-align:center;}
  .sigma-nmn .snmn-trow.head .col.us{border:1px solid var(--dark-faint);border-radius:999px;padding:2px 0;}
  .sigma-nmn .snmn-yes,.sigma-nmn .snmn-no{display:inline-block;width:11px;height:11px;border-radius:50%;}
  .sigma-nmn .snmn-yes{background:var(--green-3);}
  .sigma-nmn .snmn-no{border:1.5px solid rgba(246,244,234,.45);}
  .sigma-nmn .sr{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;}
  .sigma-nmn .snmn-note{margin:16px 0 0;font-size:.78rem;color:var(--dark-faint);text-align:center;}
