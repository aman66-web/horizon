  /* ---- 4.9 sticky CTA (fixed bottom, JS-revealed; page works without it) ---- */
  .sigma-nmn .snmn-sentinel{display:block;height:1px;}
  .sigma-nmn .snmn-sticky{position:fixed;left:0;right:0;bottom:0;z-index:40;background:var(--dark);color:var(--dark-fg);padding:10px 20px calc(10px + env(safe-area-inset-bottom));transform:translateY(110%);transition:transform .35s ease;box-shadow:0 -6px 24px rgba(13,20,15,.25);}
  .sigma-nmn .snmn-sticky.show{transform:none;}
  .sigma-nmn .snmn-sticky-in{max-width:1200px;margin-inline:auto;display:flex;align-items:center;justify-content:space-between;gap:16px;}
  .sigma-nmn .snmn-sticky-name{display:flex;align-items:center;gap:12px;min-width:0;}
  .sigma-nmn .snmn-sticky-name img{width:40px;height:40px;object-fit:contain;border-radius:8px;background:var(--cream);flex:none;}
  .sigma-nmn .snmn-sticky-name .t{font-weight:700;font-size:.95rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .sigma-nmn .snmn-sticky-name .p{color:var(--dark-faint);font-size:.9rem;flex:none;}
  .sigma-nmn .snmn-sticky form{margin:0;}
  .sigma-nmn .snmn-cta{background:var(--dark-fg);color:var(--ink);font-weight:700;font-size:.95rem;border:none;border-radius:999px;padding:12px 30px;cursor:pointer;text-decoration:none;display:inline-block;}
  .sigma-nmn .snmn-cta[disabled]{opacity:.55;cursor:default;}
  /* ---- responsive ---- */
  @media (max-width:980px){
    .sigma-nmn .snmn-tiles{grid-template-columns:repeat(2,1fr);}
    .sigma-nmn .snmn-cards{grid-template-columns:1fr;}
  }
  @media (max-width:640px){
    .sigma-nmn .snmn-inner{padding:52px 20px;}
    .sigma-nmn .snmn-tiles{grid-template-columns:1fr;}
    .sigma-nmn .snmn-std .card{flex:1 1 100%;}
    .sigma-nmn .snmn-sticky-name .p{display:none;}
  }
</style>

