.sigma-pdp .hp-eyebrow::before{content:'●'; font-size:8px; color:var(--bronze); transform:translateY(-1px);}
.sigma-pdp .actives-fig{max-width:760px; margin:0 auto 20px; border-radius:14px; overflow:hidden;}
.sigma-pdp .actives-fig img{width:100%; height:auto; display:block;}
.sigma-pdp .actives-other{max-width:640px; margin:0 auto; text-align:center; font-family:'IBM Plex Mono',monospace; font-size:12px; line-height:1.7; color:var(--ink-faint); letter-spacing:0.01em;}
.sigma-pdp .actives-other strong{color:var(--bronze); font-weight:500;}
.sigma-pdp .mission-inner{display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center;}
.sigma-pdp .mission h2{font-size:clamp(30px,3.6vw,44px); font-weight:300; line-height:1.1; letter-spacing:-0.02em; margin-bottom:20px; color:var(--ink);}
.sigma-pdp .mission p{font-size:16px; color:var(--ink-soft); line-height:1.66; margin-bottom:16px; max-width:460px;}
.sigma-pdp .mission p strong{color:var(--teal-deep); font-weight:600;}
.sigma-pdp .cert-card{background:var(--teal-deep); border-radius:6px; padding:34px; color:var(--bone); border:1px solid rgba(196,164,114,0.25);}
.sigma-pdp .cert-card + .cert-card{margin-top:18px;}
.sigma-pdp .cert-card a{color:var(--bronze-light); text-decoration:underline; text-underline-offset:3px;}
.sigma-pdp .cert-card .cert-top{display:flex; justify-content:space-between; align-items:flex-start; gap:14px; padding-bottom:20px; margin-bottom:20px; border-bottom:1px solid var(--line-light); font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:0.06em; text-transform:uppercase; color:var(--bronze-light);}
.sigma-pdp .cert-card .cert-top > span:last-child{white-space:nowrap;}
.sigma-pdp .cert-card .cert-note{color:rgba(237,231,218,0.88); font-size:14px; line-height:1.6;}
.sigma-pdp .cert-ttl{display:inline-flex; align-items:center; gap:8px;}
.sigma-pdp .cert-ttl svg{width:16px; height:16px; stroke:var(--bronze-light); fill:none; stroke-width:1.6; stroke-linecap:round; stroke-linejoin:round; flex-shrink:0;}
.sigma-pdp .cert-tests{display:flex; flex-wrap:wrap; gap:11px 20px; margin-top:20px; padding-top:18px; border-top:1px solid var(--line-light);}
.sigma-pdp .cert-tests span{display:inline-flex; align-items:center; gap:8px; font-family:'IBM Plex Mono',monospace; font-size:10.5px; letter-spacing:0.04em; text-transform:uppercase; color:rgba(237,231,218,0.72);}
.sigma-pdp .cert-tests svg{width:18px; height:18px; stroke:var(--bronze-light); fill:none; stroke-width:1.55; stroke-linecap:round; stroke-linejoin:round; flex-shrink:0;}
@media(max-width:880px){.sigma-pdp .mission-inner{grid-template-columns:1fr; gap:40px;}}
