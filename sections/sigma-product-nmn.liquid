<script>
function initSigmaNmn(){
  document.querySelectorAll('.sigma-nmn').forEach(function(root){
    if(root.dataset.sigmaInit) return;
    root.dataset.sigmaInit='1';
    var bar=root.querySelector('.snmn-sticky');
    var top=root.querySelector('.snmn-sentinel');
    var end=root.querySelector('.snmn-sentinel-end');
    if(!bar||!top||!('IntersectionObserver' in window)) return;
    var pastTop=false, nearEnd=false;
    function update(){ bar.classList.toggle('show', pastTop && !nearEnd); }
    new IntersectionObserver(function(es){
      pastTop = es[es.length-1].boundingClientRect.top < 0; update();
    },{threshold:0}).observe(top);
    if(end){
      new IntersectionObserver(function(es){
        nearEnd = es[es.length-1].isIntersecting; update();
      },{threshold:0}).observe(end);
    }
  });
}
initSigmaNmn();
document.addEventListener('DOMContentLoaded', initSigmaNmn);
document.addEventListener('shopify:section:load', initSigmaNmn);
</script>

</div>

