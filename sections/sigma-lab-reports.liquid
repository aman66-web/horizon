.sigma-lab-sec .lu-label{font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:.07em;text-transform:uppercase;color:var(--bronze-light);margin-bottom:12px}
.sigma-lab-sec .lu-row{display:flex;gap:10px}
.sigma-lab-sec .lu-row input{flex:1;background:rgba(0,0,0,.18);border:1px solid var(--line-light);border-radius:3px;padding:14px 16px;color:var(--bone);font-family:'IBM Plex Mono',monospace;font-size:14px;letter-spacing:.05em;outline:none}
.sigma-lab-sec .lu-row input::placeholder{color:rgba(237,231,218,.32)}
.sigma-lab-sec .lu-row input:focus{border-color:var(--bronze)}
.sigma-lab-sec .lu-row button{background:var(--bronze);color:var(--ink);border:none;border-radius:3px;padding:0 26px;font-size:14px;font-weight:500;cursor:pointer;transition:background .2s}
.sigma-lab-sec .lu-row button:hover{background:var(--bronze-light)}
