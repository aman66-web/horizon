.sigma-lab-sec .btn{display:inline-block;background:var(--bronze);color:var(--ink);padding:16px 32px;border-radius:2px;font-size:14.5px;font-weight:500;transition:background .2s}
.sigma-lab-sec .btn:hover{background:var(--bronze-light)}
.sigma-lab-sec .disc{padding:40px 0;font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--ink-faint);line-height:1.7;text-align:center}
