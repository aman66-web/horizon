.sigma-lab-sec .reveal{opacity:0;transform:translateY(22px);transition:opacity .8s cubic-bezier(.2,.7,.2,1),transform .8s cubic-bezier(.2,.7,.2,1)}
.sigma-lab-sec .reveal.in{opacity:1;transform:none}
@media(prefers-reduced-motion:reduce){.sigma-lab-sec .reveal{opacity:1;transform:none;transition:none}
.sigma-lab-sec{scroll-behavior:auto}}
.sigma-lab-sec .hero{padding:104px 0 78px;border-bottom:1px solid var(--line)}
.sigma-lab-sec .hero-in{display:grid;grid-template-columns:1.15fr .85fr;gap:60px;align-items:center}
.sigma-lab-sec .hero h1{font-size:clamp(40px,5.2vw,68px);line-height:1.02;font-weight:300;letter-spacing:-.028em;margin:24px 0 22px}
