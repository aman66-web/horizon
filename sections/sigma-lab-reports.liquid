<script>
const io=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.14});
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

document.querySelectorAll('.coa-head').forEach(h=>h.addEventListener('click',()=>h.parentElement.classList.toggle('open')));

const inp=document.getElementById('batchIn'), out=document.getElementById('batchOut');
document.getElementById('batchGo').addEventListener('click',()=>{
  const v=inp.value.trim().toUpperCase().replace(/[–—]/g,'-');
  out.classList.add('show');
  if(!v){ out.textContent='Enter a batch number to continue.'; return; }
  const found=[...document.querySelectorAll('.coa .bn')].find(b=>b.textContent.trim().toUpperCase().replace(/[–—]/g,'-')===v);
  if(found){
    out.textContent='✓ Batch found — opening report below.';
    const card=found.closest('.coa');
    document.querySelectorAll('.coa').forEach(c=>c.classList.remove('open'));
    card.classList.add('open');
    card.scrollIntoView({behavior:'smooth',block:'center'});
  } else {
    out.textContent='No batch matching '+v+'. Check the base of your jar, or contact us.';
  }
});
inp.addEventListener('keydown',e=>{ if(e.key==='Enter') document.getElementById('batchGo').click(); });
</script>
</div>

