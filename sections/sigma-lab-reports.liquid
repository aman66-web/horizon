.sigma-lab-sec .coa .chev{font-family:'IBM Plex Mono',monospace;color:var(--bronze);font-size:16px;transition:transform .28s;text-align:right}
.sigma-lab-sec .coa.open .chev{transform:rotate(45deg)}
.sigma-lab-sec .coa-body{max-height:0;overflow:hidden;transition:max-height .35s ease}
