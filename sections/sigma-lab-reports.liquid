.sigma-lab-sec .coa-inner{padding:4px 24px 26px;border-top:1px solid var(--line)}
.sigma-lab-sec .assay{display:grid;grid-template-columns:1.6fr 1fr 1fr .8fr;padding:13px 0;border-bottom:1px solid var(--line);font-size:14px;align-items:center}
.sigma-lab-sec .assay:last-child{border-bottom:none}
.sigma-lab-sec .assay .a-n{color:var(--ink)}
.sigma-lab-sec .assay .a-v, .sigma-lab-sec .assay .a-s{font-family:'IBM Plex Mono',monospace;font-size:13px;color:var(--ink-soft)}
.sigma-lab-sec .assay .a-p{font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:var(--green);text-align:right;letter-spacing:.04em}
.sigma-lab-sec .assay.hd{font-family:'IBM Plex Mono',monospace;font-size:9.5px;text-transform:uppercase;letter-spacing:.07em;color:var(--ink-faint)}
.sigma-lab-sec .dl{margin-top:22px;display:flex;gap:12px;flex-wrap:wrap}
.sigma-lab-sec .dl a{border:1px solid var(--line);border-radius:2px;padding:11px 20px;font-size:13px;font-weight:500;transition:border-color .2s}
.sigma-lab-sec .dl a:hover{border-color:var(--ink)}
.sigma-lab-sec .dl a.solid{background:var(--ink);color:var(--bone);border-color:var(--ink)}
@media(max-width:820px){.sigma-lab-sec .coa-head{grid-template-columns:1fr 40px;gap:12px}
.sigma-lab-sec .coa-head>div:nth-child(2), .sigma-lab-sec .coa-head>div:nth-child(3){display:none}
