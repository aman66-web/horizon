{% doc %}
  Renders all meta tags for the page including Open Graph, Twitter Cards, and SEO tags.

  @param {object} [product] - The product object, available on product pages for price meta tags.
{% enddoc %}

<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="theme-color"
  content="#0D3D3E"
>

{%- liquid
  # Brand identity is decoupled from shop.name, which still carries a
  # demo-store value ("Feral Peach"). Everything customer- and crawler-facing
  # uses this constant instead.
  assign brand_name = 'Sigma Formulas'

  assign og_title = page_title | default: brand_name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description

  if request.page_type == 'index'
    assign og_title = 'Sigma Formulas — NMN+ Daily Longevity | NAD⁺ Precursor Supplement'
    if page_description == blank and shop.description == blank
      assign og_description = 'NMN+ by Sigma Formulas — a fully disclosed NAD⁺ precursor supplement at a research-backed dose. Third-party tested for purity and potency, vegan and non-GMO.'
    endif
  endif

  if og_description == blank
    assign og_description = 'NMN+ by Sigma Formulas — a fully disclosed NAD⁺ precursor supplement, third-party tested for purity and potency.'
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ brand_name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>

{%- if page_image -%}
  <meta
    property="og:image"
    content="http:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ page_image | image_url }}"
  >
  <meta
    property="og:image:width"
    content="{{ page_image.width }}"
  >
  <meta
    property="og:image:height"
    content="{{ page_image.height }}"
  >
{%- elsif request.page_type == 'index' -%}
  {%- assign default_share_image = 'https://cdn.shopify.com/s/files/1/0816/0287/1534/files/sigma-nmn-lifestyle.png' -%}
  <meta
    property="og:image"
    content="{{ default_share_image }}?width=1200"
  >
  <meta
    property="og:image:secure_url"
    content="{{ default_share_image }}?width=1200"
  >
  <meta
    name="twitter:image"
    content="{{ default_share_image }}?width=1200"
  >
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>

<title>
  {%- if request.page_type == 'index' -%}
    {{ og_title }}
  {%- else -%}
    {{ page_title | default: brand_name }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains brand_name %} &ndash; {{ brand_name }}{% endunless -%}
  {%- endif -%}
</title>

<link
  rel="canonical"
  href="{{ canonical_url }}"
>

<meta
  name="description"
  content="{{ og_description | escape }}"
>
